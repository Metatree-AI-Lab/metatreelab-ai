---
import '../styles/global.css';
import { siteConfig, type Locale } from '../config/site';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';
import GridLines from '../components/layout/GridLines.astro';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  path?: string;
}

const {
  title,
  description = siteConfig.description[Astro.currentLocale as Locale ?? 'en'],
  locale = (Astro.currentLocale as Locale) ?? 'en',
  path = Astro.url.pathname,
} = Astro.props;

const fullTitle = title === siteConfig.name ? title : `${title} — ${siteConfig.name}`;
const canonical = new URL(path, siteConfig.url).toString();

// Build hreflang alternates
const enPath = path.replace(/^\/zh/, '') || '/';
const zhPath = `/zh${enPath === '/' ? '/' : enPath}`;
const enUrl = new URL(enPath, siteConfig.url).toString();
const zhUrl = new URL(zhPath, siteConfig.url).toString();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <!-- i18n hreflang -->
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="zh" href={zhUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale === 'zh' ? 'zh_CN' : 'en_US'} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <meta name="theme-color" content="#000000" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <GridLines />
    <Nav locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
