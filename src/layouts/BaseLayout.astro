---
import '@fontsource-variable/geist-mono';
import '../styles/global.css';
import { siteConfig, type Locale } from '../config/site';
import { useTranslations } from '../i18n';
import { buildOrganization, buildWebSite, buildBreadcrumb, breadcrumbsForPath } from '../lib/schema';
import Schema from '../components/seo/Schema.astro';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';
import GridLines from '../components/layout/GridLines.astro';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  path?: string;
  /** Extra page-specific JSON-LD blocks merged with the site-wide schema. */
  schema?: object | object[];
  /** Set true to mark the page noindex (e.g. 404, thanks). */
  noindex?: boolean;
  /** Override OG image. Defaults to /og.png (raster) with /og.svg as fallback. */
  ogImage?: string;
  /** Set true for English-only pages with no /zh counterpart (e.g. /insights/*). Omits the zh hreflang + og:locale:alternate. */
  enOnly?: boolean;
}

const {
  title,
  description = siteConfig.description[Astro.currentLocale as Locale ?? 'en'],
  locale = (Astro.currentLocale as Locale) ?? 'en',
  path = Astro.url.pathname,
  schema,
  noindex = false,
  ogImage,
  enOnly = false,
} = Astro.props;

const fullTitle = title === siteConfig.name
  ? `${siteConfig.name} — ${siteConfig.tagline[locale]}`
  : `${title} — ${siteConfig.name}`;
const canonical = new URL(path, siteConfig.url).toString();

const GA_ID = 'G-ZX8ETWFWMX';

// Build hreflang alternates
const enPath = path.replace(/^\/zh/, '') || '/';
const zhPath = `/zh${enPath === '/' ? '/' : enPath}`;
const enUrl = new URL(enPath, siteConfig.url).toString();
const zhUrl = new URL(zhPath, siteConfig.url).toString();

// OG image: prefer raster PNG so LinkedIn/WeChat/Twitter render reliably; SVG as secondary.
const ogImageUrl = ogImage
  ? new URL(ogImage, siteConfig.url).toString()
  : new URL('/og.png', siteConfig.url).toString();
const ogImageSvgUrl = new URL('/og.svg', siteConfig.url).toString();

// Site-wide JSON-LD (Organization + WebSite + Breadcrumb when applicable) + page extras.
const t = useTranslations(locale);
const breadcrumbItems = breadcrumbsForPath(path, t.breadcrumbs);
const breadcrumbSchema = breadcrumbItems ? buildBreadcrumb(breadcrumbItems, locale) : null;
const extraSchemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const allSchemas = [
  buildOrganization(locale),
  buildWebSite(locale),
  breadcrumbSchema,
  ...extraSchemas,
].filter(Boolean) as object[];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large,max-snippet:-1'}
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <!-- Fonts: Satoshi (sans) via Fontshare CDN, Geist Mono via @fontsource -->
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,600,700&display=swap"
      rel="stylesheet"
    />

    <!-- i18n hreflang -->
    {enOnly ? (
      <>
        <link rel="alternate" hreflang="en" href={enUrl} />
        <link rel="alternate" hreflang="x-default" href={enUrl} />
      </>
    ) : (
      <>
        <link rel="alternate" hreflang="en" href={enUrl} />
        <link rel="alternate" hreflang="zh" href={zhUrl} />
        <link rel="alternate" hreflang="x-default" href={enUrl} />
      </>
    )}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale === 'zh' ? 'zh_CN' : 'en_US'} />
    {!enOnly && (
      <meta property="og:locale:alternate" content={locale === 'zh' ? 'en_US' : 'zh_CN'} />
    )}
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />
    <meta property="og:image" content={ogImageSvgUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={fullTitle} />

    <meta name="theme-color" content="#000000" />
    <meta name="generator" content={Astro.generator} />

    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script is:inline define:vars={{ GA_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', GA_ID);
    </script>

    <Schema data={allSchemas} />
  </head>
  <body>
    <GridLines />
    <Nav locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />

    <script>
      function initReveal() {
        const revealItems = document.querySelectorAll('[data-reveal]');
        
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-revealed');
              // Optionally unobserve after revealing
              // observer.unobserve(entry.target);
            }
          });
        }, { 
          threshold: 0.15,
          rootMargin: '0px 0px -50px 0px' 
        });

        revealItems.forEach(item => observer.observe(item));
      }

      // Initial run
      initReveal();
      
      // Handle Astro View Transitions swaps if added later
      document.addEventListener('astro:after-swap', initReveal);
    </script>
  </body>
</html>
