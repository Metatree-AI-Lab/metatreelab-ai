---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../../config/site';
import { buildOrganization, buildBreadcrumb } from '../../lib/schema';

const posts = (await getCollection('insights'))
  .filter((p) => p.data.draft !== true)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const dateFmt = new Intl.DateTimeFormat('en-AU', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const description =
  'Practical playbooks on using AI to cut costs and grow revenue — written for business owners and founders, not engineers.';

const insightsUrl = new URL('/insights/', siteConfig.url).toString();

// Breadcrumb: Home > Insights
const breadcrumbSchema = buildBreadcrumb(
  [
    { name: 'Home', path: '/' },
    { name: 'Insights', path: '/insights/' },
  ],
  'en',
);

// Blog JSON-LD listing the published posts (refs only, not full bodies).
const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Insights',
  description,
  url: insightsUrl,
  inLanguage: 'en-AU',
  publisher: buildOrganization('en'),
  blogPost: posts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    url: new URL(`/insights/${post.id}/`, siteConfig.url).toString(),
    datePublished: post.data.pubDate.toISOString(),
  })),
};
---

<BaseLayout
  title="Insights"
  description={description}
  locale="en"
  path="/insights/"
  enOnly
  schema={[blogSchema, breadcrumbSchema]}
>
  <section class="insights-hero">
    <div class="insights-hero__inner container-x">
      <span class="section-label">/ INSIGHTS</span>
      <h1 class="insights-hero__title">AI playbooks for business owners</h1>
      <p class="insights-hero__subtitle">
        No jargon, no hype. Concrete ways to cut costs, save time, and put AI
        to work — written by people who ship this for a living.
      </p>
    </div>
  </section>

  <section class="insights-list">
    <div class="insights-list__inner container-x">
      {
        posts.length === 0 ? (
          <p class="insights-list__empty">New articles are on the way.</p>
        ) : (
          <div class="insights-grid">
            {posts.map((post) => (
              <a href={`/insights/${post.id}/`} class="card-glass insight-card">
                <span class="insight-card__date">
                  {dateFmt.format(post.data.pubDate)}
                </span>
                <h2 class="insight-card__title">{post.data.title}</h2>
                <p class="insight-card__desc">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="insight-card__tags">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="insight-card__tag">{tag}</span>
                    ))}
                  </div>
                )}
                <span class="insight-card__more">Read article →</span>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .insights-hero {
    position: relative;
    padding-block: var(--space-9) var(--space-6);
    z-index: 2;
  }

  .insights-hero__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 72rem;
  }

  .insights-hero__title {
    font-size: var(--fs-h1);
    font-weight: var(--fw-bold);
    line-height: var(--lh-tight);
    letter-spacing: -0.02em;
  }

  .insights-hero__subtitle {
    font-size: var(--fs-body-lg);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
  }

  .insights-list {
    position: relative;
    padding-block: var(--space-6) var(--space-9);
    z-index: 2;
  }

  .insights-list__empty {
    color: var(--text-secondary);
    font-size: var(--fs-body-lg);
  }

  .insights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(34rem, 1fr));
    gap: var(--space-4);
  }

  .insight-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    text-decoration: none;
  }

  .insight-card__date {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .insight-card__title {
    font-size: var(--fs-h4);
    font-weight: var(--fw-bold);
    line-height: var(--lh-snug);
    letter-spacing: -0.01em;
    color: var(--text-primary);
  }

  .insight-card__desc {
    font-size: var(--fs-body);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
  }

  .insight-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: auto;
  }

  .insight-card__tag {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-pill);
  }

  .insight-card__more {
    font-family: var(--font-mono);
    font-size: var(--fs-body-sm);
    color: var(--brand-primary);
    letter-spacing: 0.02em;
  }

  @media (max-width: 767px) {
    .insights-hero__title {
      font-size: var(--fs-h2);
    }
    .insights-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
