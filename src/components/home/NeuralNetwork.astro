---
/**
 * NeuralNetwork — multi-layer fully-connected network visual for Hero.
 *
 * Structure: 4 layers of nodes [4, 6, 6, 4] with full connections between
 * adjacent layers. Generated programmatically for accuracy and density.
 *
 * Design intent (design.md §5.2):
 * - Evokes both "Metatree" (branching) and "AI" (neural net)
 * - Dense, quiet, engineering-drawing aesthetic
 * - Nodes pulse with jade glow
 * - Lines use brand gradient with low opacity
 */

// Viewbox geometry
const VB_WIDTH = 520;
const VB_HEIGHT = 520;
const PADDING_X = 60;
const PADDING_Y = 60;

// Layer configuration: [input, hidden1, hidden2, output]
const LAYERS = [4, 6, 6, 4];

// Compute node positions for each layer
type Node = { x: number; y: number; r: number; layerIdx: number; nodeIdx: number };

const usableWidth = VB_WIDTH - PADDING_X * 2;
const usableHeight = VB_HEIGHT - PADDING_Y * 2;

const nodes: Node[][] = LAYERS.map((count, layerIdx) => {
  const x = PADDING_X + (usableWidth * layerIdx) / (LAYERS.length - 1);

  // Middle layers get slightly larger radius, edges smaller
  const r = layerIdx === 0 || layerIdx === LAYERS.length - 1 ? 3.2 : 3.6;

  // Distribute nodes vertically, slight random-looking offset per layer for organic feel
  return Array.from({ length: count }, (_, nodeIdx) => {
    const step = usableHeight / (count - 1 || 1);
    const y = PADDING_Y + step * nodeIdx;
    return { x, y, r, layerIdx, nodeIdx };
  });
});

// Generate all connections (layer N → layer N+1, fully connected)
type Connection = { x1: number; y1: number; x2: number; y2: number; delay: number };

const connections: Connection[] = [];
for (let L = 0; L < nodes.length - 1; L++) {
  const from = nodes[L];
  const to = nodes[L + 1];
  for (const a of from) {
    for (const b of to) {
      // Stagger the "data flow" animation across connections
      const delay = (L * 0.6 + (a.nodeIdx + b.nodeIdx) * 0.04) % 4;
      connections.push({ x1: a.x, y1: a.y, x2: b.x, y2: b.y, delay });
    }
  }
}

// Flatten nodes for rendering with unique pulse delays
const allNodes = nodes.flat().map((n, i) => ({
  ...n,
  pulseDelay: (i * 0.17) % 3,
}));
---

<div class="nn" aria-hidden="true">
  <svg
    viewBox={`0 0 ${VB_WIDTH} ${VB_HEIGHT}`}
    xmlns="http://www.w3.org/2000/svg"
    class="nn__svg"
  >
    <defs>
      <linearGradient id="nnEdgeGrad" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#00E5A0" stop-opacity="0.35" />
        <stop offset="50%" stop-color="#7DF9C5" stop-opacity="0.55" />
        <stop offset="100%" stop-color="#00B4D8" stop-opacity="0.35" />
      </linearGradient>

      <radialGradient id="nnNodeGrad" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#7DF9C5" stop-opacity="1" />
        <stop offset="60%" stop-color="#00E5A0" stop-opacity="0.9" />
        <stop offset="100%" stop-color="#00B4D8" stop-opacity="0.3" />
      </radialGradient>

      <filter id="nnGlow" x="-80%" y="-80%" width="260%" height="260%">
        <feGaussianBlur stdDeviation="3" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    {/* Edges (connections) — fully connected between adjacent layers */}
    <g class="nn__edges" stroke="url(#nnEdgeGrad)" stroke-width="0.6" fill="none">
      {
        connections.map((c) => (
          <line
            x1={c.x1}
            y1={c.y1}
            x2={c.x2}
            y2={c.y2}
            class="nn__edge"
            style={`animation-delay: ${c.delay}s`}
          />
        ))
      }
    </g>

    {/* Nodes */}
    <g class="nn__nodes" filter="url(#nnGlow)">
      {
        allNodes.map((n) => (
          <circle
            cx={n.x}
            cy={n.y}
            r={n.r}
            fill="url(#nnNodeGrad)"
            class="nn__node"
            style={`animation-delay: ${n.pulseDelay}s`}
          />
        ))
      }
    </g>

    {/* Outer node rings — crisp dot on top of glow */}
    <g class="nn__rings">
      {
        allNodes.map((n) => (
          <circle
            cx={n.x}
            cy={n.y}
            r={n.r * 0.55}
            fill="#7DF9C5"
            class="nn__ring"
            style={`animation-delay: ${n.pulseDelay}s`}
          />
        ))
      }
    </g>
  </svg>

  {/* Background glow */}
  <div class="nn__glow"></div>
</div>

<style>
  .nn {
    position: relative;
    width: 100%;
    max-width: 56rem;
    aspect-ratio: 1 / 1;
    justify-self: end;
  }

  .nn__svg {
    width: 100%;
    height: 100%;
    display: block;
    position: relative;
    z-index: 2;
  }

  /* Edges: pulse opacity to simulate data flow */
  .nn__edge {
    opacity: 0.25;
    animation: edgePulse 4s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes edgePulse {
    0%, 100% { opacity: 0.15; }
    50%      { opacity: 0.55; }
  }

  /* Nodes: slow pulse with glow */
  .nn__node {
    opacity: 0.75;
    animation: nodePulse 3.5s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes nodePulse {
    0%, 100% { opacity: 0.55; transform-origin: center; }
    50%      { opacity: 1; }
  }

  /* Inner bright ring */
  .nn__ring {
    opacity: 0.9;
    animation: ringPulse 3.5s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes ringPulse {
    0%, 100% { opacity: 0.7; }
    50%      { opacity: 1; }
  }

  /* Ambient background glow */
  .nn__glow {
    position: absolute;
    inset: 10% 10% 10% 10%;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(0, 229, 160, 0.28) 0%,
      rgba(0, 180, 216, 0.12) 45%,
      transparent 75%
    );
    filter: blur(70px);
    opacity: 0.55;
    z-index: 1;
    animation: breathe 5s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes breathe {
    0%, 100% { opacity: 0.4; transform: scale(0.92); }
    50%      { opacity: 0.65; transform: scale(1.08); }
  }

  @media (max-width: 991px) {
    .nn {
      max-width: 36rem;
      justify-self: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nn__edge,
    .nn__node,
    .nn__ring,
    .nn__glow {
      animation: none;
    }
    .nn__edge { opacity: 0.35; }
    .nn__node { opacity: 0.9; }
  }
</style>
