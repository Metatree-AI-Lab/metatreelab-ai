---
import type { Locale } from '../../config/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const label = locale === 'zh' ? '关键数据' : 'BY THE NUMBERS';

const stats = locale === 'zh'
  ? [
      { value: '70', unit: '%', caption: '平均帮客户降低的运营成本' },
      { value: '50+', unit: '', caption: '家企业选择与我们合作' },
      { value: '10+', unit: '', caption: '套 AI 系统每天在为客户工作' },
      { value: '3', unit: '城', caption: '布里斯班 · 墨尔本 · 阿德莱德' },
    ]
  : [
      { value: '70', unit: '%', caption: 'Avg. cost reduction for clients' },
      { value: '50+', unit: '', caption: 'Businesses chose to work with us' },
      { value: '10+', unit: '', caption: 'AI systems working for clients daily' },
      { value: '3', unit: '', caption: 'Offices across Australia' },
    ];
---

<section class="stats">
  <div class="stats__inner container-x">
    <span class="section-label">/ 08 — {label}</span>

    <div class="stats__grid">
      {
        stats.map((s) => (
          <div class="stats__item">
            <div class="stats__value">
              <span class="stats__number" data-value={s.value.replace('+', '')}>
                0
              </span>
              {s.value.includes('+') && <span class="stats__plus">+</span>}
              {s.unit && <span class="stats__unit">{s.unit}</span>}
            </div>
            <div class="stats__rule" aria-hidden="true"></div>
            <div class="stats__caption">{s.caption}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  function animateStats() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const target = entry.target as HTMLElement;
          const numberEl = target.querySelector('.stats__number') as HTMLElement;
          const ruleEl = target.querySelector('.stats__rule') as HTMLElement;
          
          if (!numberEl || target.dataset.animated === 'true') return;
          
          const endValue = parseInt(numberEl.dataset.value || '0', 10);
          const duration = 1500;
          const startTime = performance.now();
          
          function update(currentTime: number) {
            const elapsed = currentTime - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const easeProgress = 1 - Math.pow(1 - progress, 3);
            const currentValue = Math.floor(easeProgress * endValue);
            
            numberEl.textContent = currentValue.toString();
            
            if (progress < 1) {
              requestAnimationFrame(update);
            } else {
              numberEl.textContent = endValue.toString();
            }
          }
          
          requestAnimationFrame(update);
          if (ruleEl) ruleEl.style.transform = 'scaleX(1)';
          target.dataset.animated = 'true';
        }
      });
    }, { threshold: 0.2 });

    document.querySelectorAll('.stats__item').forEach(item => observer.observe(item));
  }

  animateStats();
  document.addEventListener('astro:after-swap', animateStats);
</script>

<style>
  .stats {
    position: relative;
    padding-block: var(--space-8);
    z-index: 2;
  }

  .stats__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .stats__value {
    font-family: var(--font-sans);
    font-size: 9.6rem;
    font-weight: var(--fw-bold);
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    display: flex;
    align-items: baseline;
    gap: 0.2rem;
  }

  .stats__plus {
    font-size: 0.6em;
    color: var(--brand-primary);
    margin-left: -0.1em;
  }

  .stats__unit {
    font-size: var(--fs-h4);
    font-family: var(--font-mono);
    font-weight: var(--fw-medium);
    letter-spacing: 0.04em;
    color: var(--text-tertiary);
    text-transform: uppercase;
  }

  .stats__rule {
    height: 1px;
    width: 100%;
    background: var(--border-hairline);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .stats__caption {
    font-family: var(--font-mono);
    font-size: var(--fs-body-sm);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: var(--lh-snug);
  }

  @media (max-width: 991px) {
    .stats__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6) var(--space-5);
    }
    .stats__value {
      font-size: 7.2rem;
    }
  }

  @media (max-width: 480px) {
    .stats__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
