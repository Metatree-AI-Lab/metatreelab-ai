---
import type { Locale } from '../../config/site';
import { siteConfig, localizedHref } from '../../config/site';
import { useTranslations } from '../../i18n/index';
import { deckSlides } from '../../data/deck';
import Logo from '../ui/Logo.astro';
import SlideCover from './SlideCover.astro';
import SlideProblem from './SlideProblem.astro';
import SlideWhoWeAre from './SlideWhoWeAre.astro';
import SlideWhatWeDo from './SlideWhatWeDo.astro';
import SlideBuild from './SlideBuild.astro';
import SlideAdopt from './SlideAdopt.astro';
import SlideProperty from './SlideProperty.astro';
import SlideCases from './SlideCases.astro';
import SlideProcess from './SlideProcess.astro';
import SlideEngagement from './SlideEngagement.astro';
import SlideTeam from './SlideTeam.astro';
import SlideWhyUs from './SlideWhyUs.astro';
import SlideCta from './SlideCta.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const total = deckSlides.length;
const lang = locale === 'zh' ? 'zh' : 'en';
const homeHref = localizedHref('/', locale);
const title = `${siteConfig.name} — ${t.deck.pageTitle}`;
const description = siteConfig.description[locale];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,600,700,800&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Top bar -->
  <div class="deck-topbar">
    <a href={homeHref} class="deck-home" aria-label={t.deck.backToSite}>
      <Logo showText={false} />
    </a>
    <div class="deck-topbar-right">
      <span class="deck-counter">
        <span id="currentSlide">01</span> / <span>{String(total).padStart(2, '0')}</span>
      </span>
      <button class="deck-fs-btn" id="fsBtn" aria-label={t.deck.fullscreen} title={t.deck.fullscreen}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 3H5a2 2 0 00-2 2v3m18 0V5a2 2 0 00-2-2h-3m0 18h3a2 2 0 002-2v-3M3 16v3a2 2 0 002 2h3" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Slide viewport -->
  <div class="deck-viewport" id="deckViewport">
    <div class="deck-container" id="deckContainer">
      <div class="deck-slide active" data-slide="0"><SlideCover locale={locale} /></div>
      <div class="deck-slide" data-slide="1"><SlideProblem locale={locale} /></div>
      <div class="deck-slide" data-slide="2"><SlideWhoWeAre locale={locale} /></div>
      <div class="deck-slide" data-slide="3"><SlideWhatWeDo locale={locale} /></div>
      <div class="deck-slide" data-slide="4"><SlideBuild locale={locale} /></div>
      <div class="deck-slide" data-slide="5"><SlideAdopt locale={locale} /></div>
      <div class="deck-slide" data-slide="6"><SlideProperty locale={locale} /></div>
      <div class="deck-slide" data-slide="7"><SlideCases locale={locale} /></div>
      <div class="deck-slide" data-slide="8"><SlideProcess locale={locale} /></div>
      <div class="deck-slide" data-slide="9"><SlideEngagement locale={locale} /></div>
      <div class="deck-slide" data-slide="10"><SlideTeam locale={locale} /></div>
      <div class="deck-slide" data-slide="11"><SlideWhyUs locale={locale} /></div>
      <div class="deck-slide" data-slide="12"><SlideCta locale={locale} /></div>
    </div>
  </div>

  <!-- Dot indicator -->
  <div class="deck-dots" id="deckDots">
    {deckSlides.map((_, i) => (
      <button
        class={`deck-dot ${i === 0 ? 'active' : ''}`}
        data-dot={i}
        aria-label={`Slide ${i + 1}`}
      />
    ))}
  </div>

  <!-- Click zones for left/right navigation -->
  <div class="deck-click-zone deck-click-left" id="clickLeft" aria-hidden="true"></div>
  <div class="deck-click-zone deck-click-right" id="clickRight" aria-hidden="true"></div>

  <script is:inline define:vars={{ total }}>
    const slides = document.querySelectorAll('.deck-slide');
    const dots = document.querySelectorAll('.deck-dot');
    const counter = document.getElementById('currentSlide');
    const fsBtn = document.getElementById('fsBtn');
    const clickLeft = document.getElementById('clickLeft');
    const clickRight = document.getElementById('clickRight');
    let current = 0;

    // Read initial slide from hash
    const hashMatch = location.hash.match(/^#(\d+)$/);
    if (hashMatch) {
      const idx = parseInt(hashMatch[1], 10) - 1;
      if (idx >= 0 && idx < total) {
        current = idx;
        slides.forEach((s, i) => s.classList.toggle('active', i === current));
        dots.forEach((d, i) => d.classList.toggle('active', i === current));
        counter.textContent = String(current + 1).padStart(2, '0');
      }
    }

    function goTo(index) {
      if (index < 0 || index >= total || index === current) return;
      const prev = slides[current];
      const next = slides[index];
      const direction = index > current ? 1 : -1;

      prev.style.setProperty('--exit-x', `${-direction * 3}%`);
      next.style.setProperty('--enter-x', `${direction * 3}%`);

      prev.classList.remove('active');
      prev.classList.add('exiting');
      next.classList.add('entering', 'active');

      setTimeout(() => {
        prev.classList.remove('exiting');
        next.classList.remove('entering');
      }, 450);

      current = index;
      history.replaceState(null, '', `#${current + 1}`);
      counter.textContent = String(current + 1).padStart(2, '0');
      dots.forEach((d, i) => d.classList.toggle('active', i === current));

      // Trigger stagger animations for child elements
      const items = next.querySelectorAll('[data-deck-reveal]');
      items.forEach((el, i) => {
        el.classList.remove('is-visible');
        setTimeout(() => el.classList.add('is-visible'), 80 + i * 80);
      });
    }

    // Initial reveal for first slide
    setTimeout(() => {
      const items = slides[current].querySelectorAll('[data-deck-reveal]');
      items.forEach((el, i) => {
        setTimeout(() => el.classList.add('is-visible'), 200 + i * 100);
      });
    }, 100);

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === ' ' || e.key === 'PageDown') {
        e.preventDefault();
        goTo(current + 1);
      }
      if (e.key === 'ArrowLeft' || e.key === 'PageUp') {
        e.preventDefault();
        goTo(current - 1);
      }
      if (e.key === 'f' || e.key === 'F') toggleFullscreen();
      if (e.key === 'Home') { e.preventDefault(); goTo(0); }
      if (e.key === 'End') { e.preventDefault(); goTo(total - 1); }
    });

    // Touch swipe
    let touchStartX = 0;
    let touchStartY = 0;
    document.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }, { passive: true });
    document.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 50) {
        if (dx < 0) goTo(current + 1);
        else goTo(current - 1);
      }
    }, { passive: true });

    // Click zones
    clickLeft.addEventListener('click', () => goTo(current - 1));
    clickRight.addEventListener('click', () => goTo(current + 1));

    // Dots
    dots.forEach((dot) => {
      dot.addEventListener('click', () => goTo(parseInt(dot.dataset.dot, 10)));
    });

    // Fullscreen
    function toggleFullscreen() {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen?.();
      } else {
        document.exitFullscreen?.();
      }
    }
    fsBtn.addEventListener('click', toggleFullscreen);
  </script>

  <style is:global>
    /* Reset for deck page — independent from main site */
    html {
      font-size: 62.5%;
      background: #000;
      color: #fff;
      font-family: "Satoshi", "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    html[lang="zh"] {
      font-family: "Noto Sans SC", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
    }
    body {
      margin: 0;
      overflow: hidden;
      background: #000;
      width: 100vw;
      height: 100vh;
    }
    *, *::before, *::after { box-sizing: border-box; }

    /* ---- Design tokens (subset for deck) ---- */
    :root {
      --bg-base: #000000;
      --bg-elevated: #0a0a0b;
      --bg-glass: rgba(255, 255, 255, 0.03);
      --text-primary: #ffffff;
      --text-secondary: rgba(255, 255, 255, 0.65);
      --text-tertiary: rgba(255, 255, 255, 0.45);
      --text-muted: rgba(255, 255, 255, 0.30);
      --border-hairline: rgba(255, 255, 255, 0.08);
      --border-strong: rgba(255, 255, 255, 0.15);
      --brand-primary: #00e5a0;
      --brand-secondary: #00b4d8;
      --brand-accent: #7df9c5;
      --brand-gradient: linear-gradient(135deg, #00e5a0 0%, #00c89e 25%, #00b4d8 60%, #0095c4 100%);
      --brand-glow: radial-gradient(circle, rgba(0,229,160,0.35) 0%, rgba(0,180,216,0.15) 50%, transparent 100%);
      --font-sans: "Satoshi", "Inter", -apple-system, sans-serif;
      --font-mono: "Geist Mono", "JetBrains Mono", "SF Mono", Menlo, monospace;
      --font-sans-zh: "Noto Sans SC", "PingFang SC", sans-serif;
      --radius-sm: 0.8rem;
      --radius-md: 1.2rem;
      --radius-lg: 2.4rem;
      --shadow-card: inset 1px 1px 0 rgba(255,255,255,0.06), inset -1px -1px 0 rgba(255,255,255,0.04), 0 10px 30px rgba(0,0,0,0.4);
      --shadow-glow: 0 0 40px rgba(0,229,160,0.15), 0 0 80px rgba(0,180,216,0.08);
      --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* ---- Top bar ---- */
    .deck-topbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.6rem 2.4rem;
      pointer-events: none;
    }
    .deck-topbar > * { pointer-events: auto; }
    .deck-home {
      opacity: 0.5;
      transition: opacity 0.3s;
    }
    .deck-home:hover { opacity: 1; }

    .deck-topbar-right {
      display: flex;
      align-items: center;
      gap: 1.6rem;
    }
    .deck-counter {
      font-family: var(--font-mono);
      font-size: 1.2rem;
      color: var(--text-tertiary);
      letter-spacing: 0.1em;
    }
    .deck-fs-btn {
      background: none;
      border: 1px solid var(--border-hairline);
      border-radius: var(--radius-sm);
      color: var(--text-tertiary);
      padding: 0.6rem;
      cursor: pointer;
      transition: all 0.3s;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .deck-fs-btn:hover {
      color: var(--text-primary);
      border-color: var(--brand-primary);
    }

    /* ---- Slide viewport ---- */
    .deck-viewport {
      width: 100vw;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #000;
    }
    .deck-container {
      width: min(100vw, calc(100vh * 16 / 9));
      height: min(100vh, calc(100vw * 9 / 16));
      position: relative;
      overflow: hidden;
      background: var(--bg-base);
      /* Subtle border to frame the slide */
      border: 1px solid var(--border-hairline);
    }

    /* ---- Individual slides ---- */
    .deck-slide {
      position: absolute;
      inset: 0;
      opacity: 0;
      pointer-events: none;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.4s var(--ease-out), transform 0.4s var(--ease-out);
    }
    .deck-slide.active {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(0);
    }
    .deck-slide.exiting {
      opacity: 0;
      transform: translateX(var(--exit-x, -3%));
      pointer-events: none;
    }
    .deck-slide.entering {
      animation: slideEnter 0.4s var(--ease-out) forwards;
    }
    @keyframes slideEnter {
      from {
        opacity: 0;
        transform: translateX(var(--enter-x, 3%));
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    /* ---- Slide inner content area ---- */
    .slide-inner {
      width: 100%;
      height: 100%;
      padding: 6% 7%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
    }

    /* ---- Section labels ---- */
    .slide-label {
      font-family: var(--font-mono);
      font-size: clamp(0.9rem, 1.2cqi, 1.2rem);
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      position: absolute;
      top: 6%;
      left: 7%;
    }

    /* ---- Slide typography ---- */
    .slide-title {
      font-family: var(--font-sans);
      font-size: clamp(2.8rem, 4.5cqi, 5.4rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--text-primary);
      white-space: pre-line;
      margin: 0;
    }
    html[lang="zh"] .slide-title {
      font-family: var(--font-sans-zh);
      line-height: 1.3;
    }

    .slide-subtitle {
      font-size: clamp(1.4rem, 1.8cqi, 2rem);
      color: var(--text-secondary);
      margin-top: 1.6rem;
      line-height: 1.5;
      max-width: 70%;
    }

    /* ---- Glass card ---- */
    .deck-card {
      background: var(--bg-glass);
      backdrop-filter: blur(16px) saturate(120%);
      -webkit-backdrop-filter: blur(16px) saturate(120%);
      border: 1px solid var(--border-hairline);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-card);
      padding: 2.4rem;
    }

    /* ---- Stat number ---- */
    .stat-value {
      font-family: var(--font-mono);
      font-size: clamp(3.2rem, 6cqi, 7.2rem);
      font-weight: 700;
      color: var(--brand-primary);
      line-height: 1;
    }
    .stat-label {
      font-size: clamp(1rem, 1.3cqi, 1.4rem);
      color: var(--text-secondary);
      margin-top: 0.6rem;
      line-height: 1.4;
    }

    /* ---- Buttons ---- */
    .deck-btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.8rem;
      padding: 1.4rem 2.8rem;
      border-radius: var(--radius-md);
      background: var(--bg-glass);
      backdrop-filter: blur(8px);
      border: 1px solid var(--border-hairline);
      color: var(--text-primary);
      font-family: var(--font-mono);
      font-size: clamp(1.1rem, 1.4cqi, 1.4rem);
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      text-decoration: none;
      cursor: pointer;
      transition: border-color 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out);
    }
    .deck-btn-primary:hover {
      border-color: var(--brand-primary);
      box-shadow: var(--shadow-glow);
      color: var(--text-primary);
    }
    .deck-btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 0.8rem;
      padding: 1.4rem 2.8rem;
      border-radius: var(--radius-md);
      border: 1px solid transparent;
      color: var(--text-secondary);
      font-family: var(--font-mono);
      font-size: clamp(1.1rem, 1.4cqi, 1.4rem);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      text-decoration: none;
      cursor: pointer;
      transition: all 0.4s var(--ease-out);
    }
    .deck-btn-ghost:hover {
      color: var(--text-primary);
      border-color: var(--border-hairline);
    }

    /* ---- Dot indicator ---- */
    .deck-dots {
      position: fixed;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 0.8rem;
      z-index: 100;
    }
    .deck-dot {
      width: 0.8rem;
      height: 0.8rem;
      border-radius: 50%;
      border: none;
      background: var(--text-muted);
      cursor: pointer;
      transition: all 0.3s var(--ease-out);
      padding: 0;
    }
    .deck-dot.active {
      background: var(--brand-primary);
      box-shadow: 0 0 8px rgba(0,229,160,0.5);
      transform: scale(1.3);
    }
    .deck-dot:hover:not(.active) {
      background: var(--text-tertiary);
    }

    /* ---- Click zones ---- */
    .deck-click-zone {
      position: fixed;
      top: 0;
      width: 15%;
      height: 100%;
      z-index: 50;
      cursor: pointer;
    }
    .deck-click-left { left: 0; }
    .deck-click-right { right: 0; }

    /* ---- Deck reveal animation ---- */
    [data-deck-reveal] {
      opacity: 0;
      transform: translateY(1.6rem);
      filter: blur(6px);
      transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out), filter 0.7s var(--ease-out);
    }
    [data-deck-reveal].is-visible {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }

    /* ---- Breathing glow ---- */
    @keyframes breathe {
      0%, 100% { opacity: 0.4; transform: scale(1); }
      50% { opacity: 0.7; transform: scale(1.05); }
    }
    .glow-bg {
      position: absolute;
      width: 40%;
      height: 50%;
      background: var(--brand-glow);
      filter: blur(80px);
      pointer-events: none;
      animation: breathe 4s ease-in-out infinite;
    }

    /* ---- Brand gradient text ---- */
    .gradient-text {
      background: var(--brand-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ---- Accessibility ---- */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
    }

    /* ---- Mobile: scroll mode ---- */
    @media (max-width: 767px) {
      body { overflow: auto; }

      .deck-container {
        width: 100vw;
        height: auto;
        border: none;
        display: flex;
        flex-direction: column;
      }
      .deck-slide {
        position: relative;
        opacity: 1;
        pointer-events: auto;
        width: 100vw;
        min-height: 100vh;
        min-height: 100svh;
      }
      .deck-slide.exiting,
      .deck-slide.entering {
        animation: none;
        transform: none;
        opacity: 1;
      }
      .slide-inner {
        padding: 8rem 2.4rem 4rem;
      }
      .slide-label {
        position: relative;
        top: auto;
        left: auto;
        margin-bottom: 2rem;
      }
      .slide-subtitle { max-width: 100%; }

      .deck-dots { display: none; }
      .deck-click-zone { display: none; }
      .deck-topbar {
        background: rgba(0,0,0,0.8);
        backdrop-filter: blur(12px);
      }
      .deck-counter { display: none; }
      .deck-fs-btn { display: none; }

      [data-deck-reveal] {
        opacity: 1;
        transform: none;
        filter: none;
      }
    }
  </style>
</body>
</html>
