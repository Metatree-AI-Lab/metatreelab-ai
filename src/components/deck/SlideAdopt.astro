---
import type { Locale } from '../../config/site';
import { useTranslations } from '../../i18n/index';
import { deckSlides } from '../../data/deck';
import { services } from '../../data/services';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const slide = deckSlides[5];

const adoptServices = services.filter(s => s.track === 'adopt');
---

<div class="slide-inner">
  <span class="slide-label">{slide.label}</span>

  <h2 class="slide-title" data-deck-reveal>{slide.title[locale]}</h2>

  <div class="adopt-grid">
    {adoptServices.map((svc) => (
      <div class="adopt-card deck-card" data-deck-reveal>
        {svc.flagship && <span class="adopt-flag">FLAGSHIP</span>}
        <h3 class="adopt-name">{svc.title[locale]}</h3>
        <p class="adopt-desc">{svc.subtitle[locale]}</p>
        <div class="adopt-meta">
          <span class="adopt-dur">{svc.duration}</span>
          <div class="adopt-tags">
            {svc.tags.slice(0, 3).map((tag) => (
              <span class="adopt-tag">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .adopt-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.2rem, 2cqi, 2rem);
    margin-top: clamp(2.4rem, 4cqi, 4rem);
  }
  .adopt-card {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .adopt-flag {
    font-family: var(--font-mono);
    font-size: clamp(0.8rem, 1cqi, 1rem);
    color: var(--brand-primary);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .adopt-name {
    font-size: clamp(1.4rem, 2cqi, 2rem);
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.2;
  }
  .adopt-desc {
    font-size: clamp(1rem, 1.3cqi, 1.3rem);
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }
  .adopt-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 1.2rem;
    border-top: 1px solid var(--border-hairline);
  }
  .adopt-dur {
    font-family: var(--font-mono);
    font-size: clamp(0.9rem, 1.1cqi, 1.1rem);
    color: var(--text-muted);
  }
  .adopt-tags {
    display: flex;
    gap: 0.6rem;
  }
  .adopt-tag {
    font-family: var(--font-mono);
    font-size: clamp(0.8rem, 0.9cqi, 0.9rem);
    color: var(--text-tertiary);
    background: rgba(255,255,255,0.04);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
  }
  @media (max-width: 767px) {
    .adopt-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
