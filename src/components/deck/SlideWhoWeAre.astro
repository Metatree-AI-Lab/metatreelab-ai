---
import type { Locale } from '../../config/site';
import { useTranslations } from '../../i18n/index';
import { deckSlides, backingStats } from '../../data/deck';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const slide = deckSlides[2];
---

<div class="slide-inner">
  <span class="slide-label">{slide.label}</span>

  <h2 class="slide-title" data-deck-reveal>{slide.title[locale]}</h2>

  <div class="who-stats">
    {backingStats.map((stat) => (
      <div class="who-stat" data-deck-reveal>
        <div class="stat-value">{stat.value}</div>
        <div class="stat-label">{stat.label[locale]}</div>
      </div>
    ))}
  </div>

  <p class="who-backing deck-card" data-deck-reveal>{t.deck.parentBacking}</p>
</div>

<style>
  .who-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1.6rem, 2.5cqi, 3.2rem);
    margin-top: clamp(2.4rem, 4cqi, 4.8rem);
  }
  .who-stat {
    text-align: center;
  }
  .who-backing {
    margin-top: clamp(2rem, 3cqi, 3.2rem);
    font-size: clamp(1.2rem, 1.5cqi, 1.6rem);
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 80%;
  }
  @media (max-width: 767px) {
    .who-stats {
      grid-template-columns: repeat(2, 1fr);
    }
    .who-backing { max-width: 100%; }
  }
</style>
