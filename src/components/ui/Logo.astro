---
interface Props {
  className?: string;
  showText?: boolean;
}

const { className = '', showText = true } = Astro.props;
---

<div class={`logo-group ${className}`} aria-label="Metatree Lab">
  <div class="logo-icon-wrapper">
    <svg
      width="28"
      height="28"
      viewBox="0 0 32 32"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      class="logo-svg"
    >
      <defs>
        <linearGradient id="logoGradM_Final" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#00E5A0" />
          <stop offset="100%" stop-color="#00B4D8" />
        </linearGradient>
      </defs>

      <!-- The 'M' path - sharp, techy, and geometric -->
      <path 
        d="M5 25V7L16 17L27 7V25" 
        stroke="url(#logoGradM_Final)" 
        stroke-width="4" 
        stroke-linecap="round" 
        stroke-linejoin="round"
        class="path-m-anim"
      />
      
      <!-- Strategic Neural Nodes -->
      <circle cx="5" cy="7" r="3" fill="url(#logoGradM_Final)" class="logo-node" />
      <circle cx="27" cy="7" r="3" fill="url(#logoGradM_Final)" class="logo-node" />
      <circle cx="16" cy="17" r="3" fill="url(#logoGradM_Final)" class="logo-node logo-node--center" />
    </svg>
  </div>

  {showText && (
    <div class="logo-text">
      <span class="text-meta">Meta</span><span class="text-tree">tree</span>
    </div>
  )}
</div>

<style>
  .logo-group {
    display: inline-flex;
    align-items: center;
    gap: 1.2rem;
    cursor: pointer;
    text-decoration: none;
  }

  .logo-icon-wrapper {
    position: relative;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-svg {
    overflow: visible;
  }

  .logo-text {
    font-family: var(--font-sans);
    font-size: 2.2rem;
    letter-spacing: -0.03em;
    color: #FFFFFF;
    display: flex;
    align-items: baseline;
    line-height: 1;
  }

  .text-meta {
    font-weight: 800; /* Extra Bold */
  }

  .text-tree {
    font-weight: 400;
    color: var(--brand-primary);
    margin-left: 0.1rem;
  }

  /* Entrance Animation */
  .path-m-anim {
    stroke-dasharray: 80;
    stroke-dashoffset: 80;
    animation: drawLogoM 1.5s cubic-bezier(0.65, 0, 0.35, 1) forwards;
  }

  /* Pulsing Center Node */
  .logo-node--center {
    animation: nodePulseLogo 3s ease-in-out infinite;
  }

  @keyframes drawLogoM {
    to { stroke-dashoffset: 0; }
  }

  @keyframes nodePulseLogo {
    0%, 100% { filter: brightness(1) drop-shadow(0 0 2px var(--brand-primary)); }
    50% { filter: brightness(1.5) drop-shadow(0 0 8px var(--brand-primary)); }
  }

  .logo-group:hover .logo-svg {
    transform: scale(1.1);
    transition: transform 0.3s var(--ease-out);
  }
  
  .logo-group:hover .text-tree {
    color: #FFFFFF;
    transition: color 0.3s var(--ease-out);
  }
</style>
