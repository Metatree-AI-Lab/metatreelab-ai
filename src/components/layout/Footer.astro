---
import { siteConfig, localizedHref, type Locale } from '../../config/site';
import { useTranslations } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container-x">
    <div class="footer__top">
      <div class="footer__brand">
        <div class="footer__logo">Metatree Lab</div>
        <p class="footer__tagline">{siteConfig.tagline[locale]}</p>
      </div>

      <div class="footer__nav">
        <a href={localizedHref('/services/', locale)}>{t.nav.services}</a>
        <a href={localizedHref('/work/', locale)}>{t.nav.work}</a>
        <a href={localizedHref('/about/', locale)}>{t.nav.about}</a>
        <a href={localizedHref('/contact/', locale)}>{t.nav.contact}</a>
      </div>
    </div>

    <div class="footer__bottom">
      <div class="footer__meta">
        <span class="section-label">© {year} {siteConfig.name}</span>
        <span class="section-label">{t.footer.parent}</span>
      </div>
      <div class="footer__links">
        <a href={siteConfig.parent.url} target="_blank" rel="noreferrer" class="section-label">
          jiangren.com.au ↗
        </a>
        <a href={siteConfig.social.github} target="_blank" rel="noreferrer" class="section-label">
          github ↗
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--space-10);
    padding-block: var(--space-7);
    border-top: 1px solid var(--border-hairline);
    position: relative;
    z-index: 2;
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .footer__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: 40rem;
  }

  .footer__logo {
    font-family: var(--font-sans);
    font-size: var(--fs-h4);
    font-weight: var(--fw-bold);
    letter-spacing: -0.02em;
  }

  .footer__tagline {
    color: var(--text-tertiary);
    font-size: var(--fs-body-sm);
  }

  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--fs-body-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .footer__nav a {
    color: var(--text-secondary);
  }

  .footer__nav a:hover {
    color: var(--brand-primary);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border-hairline);
    flex-wrap: wrap;
  }

  .footer__meta,
  .footer__links {
    display: flex;
    gap: var(--space-5);
  }
</style>
