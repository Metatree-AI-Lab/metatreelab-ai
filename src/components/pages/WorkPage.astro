---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../ui/PageHero.astro';
import CtaFooter from '../shared/CtaFooter.astro';
import ProjectThumbnail from '../ui/ProjectThumbnail.astro';
import { localizedHref, type Locale } from '../../config/site';
import { projects, type ProjectEntry } from '../../data/projects';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const copy = locale === 'zh'
  ? {
      sectionLabel: '/ WORK',
      title: 'AI 项目与数字作品集。',
      subtitle: '精选 AI 系统、房产营销、品牌网站作品 — 全部已上线生产环境。',
      filters: [
        { id: 'all', label: '全部' },
        { id: 'ai-systems', label: 'AI 系统' },
        { id: 'property', label: '房产' },
        { id: 'brand', label: '品牌' },
      ],
      client: '客户',
      empty: '暂无作品',
    }
  : {
      sectionLabel: '/ WORK',
      title: 'AI Projects & Digital Portfolio.',
      subtitle: 'Selected AI systems, property marketing, and brand work — all shipped to production.',
      filters: [
        { id: 'all', label: 'All' },
        { id: 'ai-systems', label: 'AI Systems' },
        { id: 'property', label: 'Property' },
        { id: 'brand', label: 'Brand' },
      ],
      client: 'Client',
      empty: 'No projects yet',
    };

const sorted = [...projects].sort((a, b) => a.order - b.order);
---

<BaseLayout title={copy.title} locale={locale} path={Astro.url.pathname}>
  <PageHero
    sectionLabel={copy.sectionLabel}
    title={copy.title}
    subtitle={copy.subtitle}
  />

  <section class="work">
    <div class="work__inner container-x">
      <!-- Filter tabs -->
      <div class="work__filters" role="tablist" aria-label="Filter projects">
        {
          copy.filters.map((f, i) => (
            <button
              type="button"
              class={`work__filter ${i === 0 ? 'is-active' : ''}`}
              data-filter={f.id}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
            >
              {f.label}
            </button>
          ))
        }
      </div>

      <!-- Grid -->
      <div class="work__grid" id="work-grid">
        {
          sorted.map((p: ProjectEntry, idx) => (
            <a
              href={localizedHref(`/work/${p.slug}/`, locale)}
              class={`work-card delay-${(idx % 3) + 1}`}
              data-category={p.category}
              data-reveal="3d"
            >
              <div class="work-card__cover">
                <ProjectThumbnail project={p} />
              </div>

              <div class="work-card__body">
                <div class="work-card__tags">
                  {p.tags.map((t) => (
                    <span class="work-card__tag">{t}</span>
                  ))}
                </div>
                
                <h3 class="work-card__name">{p.name}</h3>
                <p class="work-card__summary">{p.summary[locale]}</p>

                <div class="work-card__meta">
                  <span class="section-label">
                    {p.client} · {p.year}
                  </span>
                  <span class="work-card__arrow">→</span>
                </div>
              </div>
            </a>
          ))
        }
      </div>

      <div class="work__empty" id="work-empty" hidden>
        <span class="section-label">{copy.empty}</span>
      </div>
    </div>
  </section>

  <CtaFooter locale={locale} />
</BaseLayout>

<script>
  // Client-side filter — vanilla, no framework.
  const filterButtons = document.querySelectorAll<HTMLButtonElement>('.work__filter');
  const cards = document.querySelectorAll<HTMLElement>('.work-card');
  const empty = document.getElementById('work-empty');

  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';

      // Update active tab state
      filterButtons.forEach((b) => {
        b.classList.toggle('is-active', b === btn);
        b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
      });

      // Filter cards
      let visible = 0;
      cards.forEach((card) => {
        const category = card.dataset.category ?? '';
        const show = filter === 'all' || category === filter;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (empty) empty.hidden = visible > 0;
    });
  });
</script>

<style>
  .work {
    position: relative;
    padding-block: var(--space-8);
    z-index: 2;
  }

  .work__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .work__filters {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-hairline);
  }

  .work__filter {
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-pill);
    background: var(--bg-glass);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: var(--fs-body-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: all var(--dur-normal) var(--ease-out);
  }

  .work__filter:hover {
    color: var(--text-primary);
    border-color: var(--border-strong);
  }

  .work__filter.is-active {
    color: var(--brand-primary);
    border-color: var(--brand-primary);
    background: rgba(0, 229, 160, 0.08);
  }

  .work__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  .work__empty {
    padding-block: var(--space-7);
    text-align: center;
  }

  .work-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-glass);
    backdrop-filter: blur(16px) saturate(120%);
    -webkit-backdrop-filter: blur(16px) saturate(120%);
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      border-color var(--dur-normal) var(--ease-out),
      transform var(--dur-normal) var(--ease-out),
      box-shadow var(--dur-normal) var(--ease-out);
  }

  .work-card:hover {
    border-color: var(--brand-primary);
    transform: translateY(-4px);
    box-shadow: 0 0 40px rgba(0, 229, 160, 0.1);
  }

  .work-card__cover {
    position: relative;
    aspect-ratio: 16 / 10;
    border-bottom: 1px solid var(--border-hairline);
    overflow: hidden;
    background: var(--bg-elevated);
  }

  .work-card__tags {
    display: flex;
    gap: var(--space-1);
    flex-wrap: wrap;
    margin-bottom: var(--space-2);
  }

  .work-card__tag {
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 1px 6px;
    color: var(--text-tertiary);
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .work-card:hover .work-card__tag {
    border-color: var(--brand-primary);
    color: var(--brand-primary);
  }

  .work-card__body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .work-card__name {
    font-size: var(--fs-h4);
    font-weight: var(--fw-bold);
    letter-spacing: -0.01em;
    color: var(--text-primary);
  }

  .work-card__summary {
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
    flex: 1;
  }

  .work-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-3);
    margin-top: var(--space-2);
    border-top: 1px solid var(--border-hairline);
  }

  .work-card__arrow {
    color: var(--text-tertiary);
    transition: transform var(--dur-normal) var(--ease-out), color var(--dur-normal) var(--ease-out);
  }

  .work-card:hover .work-card__arrow {
    transform: translateX(4px);
    color: var(--brand-primary);
  }

  @media (max-width: 991px) {
    .work__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .work__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
