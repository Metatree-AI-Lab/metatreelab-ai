---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../ui/PageHero.astro';
import CtaFooter from '../shared/CtaFooter.astro';
import { type Locale } from '../../config/site';
import { servicesByTrack, type ServiceEntry } from '../../data/services';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const copy = locale === 'zh'
  ? {
      sectionLabel: '/ PROPERTY MARKETING',
      title: 'AI 驱动的澳洲房产营销。',
      subtitle: '我们懂澳洲房地产销售的节奏（off-the-plan、display suite、settlement），也懂华人买家市场。从开发商主站到单楼盘着陆页、品牌视觉、广告页、长期运维，一站式交付。',
      servicesHeading: '/ SERVICES — 房产营销服务',
      caseHeading: '/ CASE — 代表作品',
      caseName: 'Forma Property',
      caseDesc: '悉尼一家房地产开发商集团的主站。编辑级极简风，商业 + 住宅项目集合展示，面向投资人和高净值买家的品牌定位。',
      caseView: '查看案例 →',
      industryHeading: '/ WHY METATREE — 我们懂澳洲房产',
      industryItems: [
        { label: '销售节奏', text: '熟悉 off-the-plan / display suite / settlement 的全流程时间线' },
        { label: '合规', text: '了解 Fair Trading / VOI / Privacy Act 的营销合规要求' },
        { label: '双语', text: '原生支持英文主流市场 + 华人买家市场的双语运营（母公司匠人学院在华语市场运营 5+ 年）' },
        { label: '技术', text: '把做 AI 的工程师偏执带进房产网站 — 页面加载快、SEO 友好、CRM 对接稳' },
      ],
      deliverables: '交付内容',
    }
  : {
      sectionLabel: '/ PROPERTY MARKETING',
      title: 'AI-Powered Property Marketing for Australia.',
      subtitle: 'We understand the rhythm of Aussie property sales (off-the-plan, display suite, settlement) and we understand the Chinese buyer market. From developer group sites to single-project landing pages, brand identity, ad pages, and ongoing retainer — one shop, full delivery.',
      servicesHeading: '/ SERVICES — What we ship',
      caseHeading: '/ CASE — Reference work',
      caseName: 'Forma Property',
      caseDesc: 'Sydney-based property developer group main site. Editorial minimal aesthetic, commercial + residential portfolio, investor-grade positioning for high-net-worth buyers.',
      caseView: 'View case →',
      industryHeading: '/ WHY METATREE — We know Australian property',
      industryItems: [
        { label: 'Sales rhythm', text: 'We know the full off-the-plan / display suite / settlement timeline inside out.' },
        { label: 'Compliance', text: 'Fluent in Fair Trading / VOI / Privacy Act marketing compliance.' },
        { label: 'Bilingual', text: 'Native EN + ZH delivery for mainstream + Chinese buyer markets (our parent JR Academy has run in the Chinese-speaking market for 5+ years).' },
        { label: 'Engineering', text: 'We bring engineering discipline to property sites — fast loading, SEO-friendly, rock-solid CRM integration.' },
      ],
      deliverables: 'Deliverables',
    };

const propertyServices = servicesByTrack.property;
---

<BaseLayout title={copy.title} locale={locale} path={Astro.url.pathname}>
  <PageHero
    sectionLabel={copy.sectionLabel}
    title={copy.title}
    subtitle={copy.subtitle}
  />

  <!-- SERVICES -->
  <section class="p-services">
    <div class="p-services__inner container-x">
      <div class="p-services__header">
        <span class="section-label">{copy.servicesHeading}</span>
      </div>

      <div class="p-services__list">
        {
          propertyServices.map((s: ServiceEntry) => (
            <article class="p-service">
              <div class="p-service__top">
                <h3 class="p-service__title">{s.title[locale]}</h3>
                <span class="p-service__duration">{s.duration}</span>
              </div>
              <p class="p-service__subtitle">{s.subtitle[locale]}</p>
              <p class="p-service__summary">{s.summary[locale]}</p>

              <div class="p-service__deliverables">
                <span class="section-label">{copy.deliverables}</span>
                <ul>
                  {s.deliverables[locale].map((d) => <li>· {d}</li>)}
                </ul>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CASE STUDY -->
  <section class="p-case">
    <div class="p-case__inner container-x">
      <span class="section-label">{copy.caseHeading}</span>

      <div class="p-case__card">
        <div class="p-case__pattern"></div>
        <div class="p-case__body">
          <div class="p-case__tag section-label">PROPERTY · WEB · 2024</div>
          <h3 class="p-case__name">{copy.caseName}</h3>
          <p class="p-case__desc">{copy.caseDesc}</p>
          <a
            href="https://www.formaproperty.com.au"
            target="_blank"
            rel="noreferrer"
            class="btn-ghost"
          >
            {copy.caseView}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY METATREE -->
  <section class="p-why">
    <div class="p-why__inner container-x">
      <span class="section-label">{copy.industryHeading}</span>

      <div class="p-why__grid">
        {
          copy.industryItems.map((item, i) => (
            <div class="p-why__item">
              <span class="p-why__num section-label">/ {String(i + 1).padStart(2, '0')}</span>
              <h4 class="p-why__label">{item.label}</h4>
              <p class="p-why__text">{item.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CtaFooter locale={locale} />
</BaseLayout>

<style>
  .p-services {
    position: relative;
    padding-block: var(--space-8);
    z-index: 2;
  }

  .p-services__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .p-services__list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  .p-service {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    background: var(--bg-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-lg);
    transition: border-color var(--dur-normal) var(--ease-out);
  }

  .p-service:hover {
    border-color: var(--border-strong);
  }

  .p-service__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .p-service__title {
    font-size: var(--fs-h4);
    font-weight: var(--fw-bold);
    letter-spacing: -0.01em;
  }

  .p-service__duration {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .p-service__subtitle {
    font-size: var(--fs-body);
    color: var(--text-primary);
    font-weight: var(--fw-medium);
  }

  .p-service__summary {
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
  }

  .p-service__deliverables {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-3);
    border-top: 1px solid var(--border-hairline);
  }

  .p-service__deliverables ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .p-service__deliverables li {
    font-family: var(--font-mono);
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
  }

  /* Case study */
  .p-case {
    position: relative;
    padding-block: var(--space-8);
    border-top: 1px solid var(--border-hairline);
    z-index: 2;
  }

  .p-case__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .p-case__card {
    position: relative;
    padding: var(--space-7);
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.02),
      rgba(0, 180, 216, 0.04)
    );
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .p-case__pattern {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        135deg,
        transparent 0,
        transparent 32px,
        rgba(255, 255, 255, 0.015) 32px,
        rgba(255, 255, 255, 0.015) 33px
      );
    pointer-events: none;
  }

  .p-case__body {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 72rem;
  }

  .p-case__tag {
    color: var(--text-tertiary);
  }

  .p-case__name {
    font-size: var(--fs-h2);
    font-weight: var(--fw-bold);
    letter-spacing: -0.02em;
  }

  .p-case__desc {
    font-size: var(--fs-body-lg);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
  }

  .p-case__card .btn-ghost {
    align-self: flex-start;
    margin-top: var(--space-2);
  }

  /* Why Metatree */
  .p-why {
    position: relative;
    padding-block: var(--space-8);
    border-top: 1px solid var(--border-hairline);
    z-index: 2;
  }

  .p-why__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .p-why__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: 1px solid var(--border-hairline);
  }

  .p-why__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-5) var(--space-5) 0;
    border-bottom: 1px solid var(--border-hairline);
  }

  .p-why__item:nth-child(odd) {
    border-right: 1px solid var(--border-hairline);
    padding-right: var(--space-5);
  }

  .p-why__item:nth-child(even) {
    padding-left: var(--space-5);
  }

  .p-why__num {
    color: var(--text-tertiary);
  }

  .p-why__label {
    font-size: var(--fs-h4);
    font-weight: var(--fw-bold);
    letter-spacing: -0.01em;
  }

  .p-why__text {
    font-size: var(--fs-body);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
  }

  @media (max-width: 991px) {
    .p-services__list,
    .p-why__grid {
      grid-template-columns: 1fr;
    }
    .p-why__item:nth-child(odd),
    .p-why__item:nth-child(even) {
      border-right: none;
      padding: var(--space-5) 0;
    }
    .p-case__name { font-size: var(--fs-h3); }
  }
</style>
