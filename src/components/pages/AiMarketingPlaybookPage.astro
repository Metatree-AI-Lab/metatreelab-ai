          { icon: '💼', name: 'LinkedIn', skill: '/linkedin-variant', text: 'Professional tone · long-form · industry hashtags', image: '1200×627 banner · clean layout' },
          { icon: '📰', name: 'WeChat MP', skill: '/mp-variant', text: '1500-2500 chars · formatted + quotes + CTA', image: '900×500 header + body images' },
        ],
        publish: { layer: 'LAYER 03', name: 'Parallel Publish', detail: ['4-platform simultaneous publish', 'Schedule + offset peaks', 'Engagement ingest'], skill: '/publisher' },
        feedbackBadge: 'FEEDBACK LOOP',
        feedbackText: '4-platform engagement → flows back to Master → AI learns "which hook / which image works on which platform" → next Master is data-driven',
        vsBadge: 'VS STEP 3',
        vsText: 'Edit one data point / hook / claim = 4 platforms updated simultaneously. This is a team-scale pipeline.',
        servicePill: { label: 'Metatree delivers', value: 'AI Agent Workflow Automation · Custom LLM Applications', href: '/services/ai/' },
      },

      step4: {
        badge: 'STEP 4',
        badgeLabel: 'Full pipeline + learning loop',
        title: 'A system that gets better on its own — this is an AI-native team.',
        desc: 'Five-node loop + central feedback hub. Engagement flows back, AI adjusts weights, the next round picks topics more accurately.',
        nodes: [
          { id: 'collect', label: 'Data collection', sub: 'Reddit / X / RSS' },
          { id: 'decide', label: 'Topic decision', sub: 'AI agent ranks Top 3' },
          { id: 'generate', label: '4-platform gen', sub: 'Copy + imagery' },
          { id: 'publish', label: 'Publish', sub: 'Buffer auto-schedule' },
          { id: 'track', label: 'Track + feedback', sub: '6h · 24h · 7d metrics' },
        ],
        feedbackHubLabel: 'FEEDBACK',
        feedbackHubName: 'Learning hub',
        feedbackHubDetail: 'Updates prompts + weights',
        compare: [
          {
            side: 'TRADITIONAL',
            team: 'Legacy marketing team · 6 people',
            detail: ['2 on topics + copy', '1 on design', '1 on multi-platform publishing', '2 on monitoring + retro'],
            time: '4 hours/day',
            output: '4 platforms · 1× output',
          },
          {
            side: 'AI-NATIVE',
            team: 'AI-native team · 1 person',
            detail: ['Pipeline runs itself', 'AI agent picks topics', 'AI generates + publishes', '1 person monitors + tunes'],
            time: '30 min/day',
            output: '4 platforms · 3× output',
          },
        ],
        servicePill: { label: 'Metatree delivers', value: 'Hermes Agent Implementation · Workflow Automation', href: '/services/ai/' },
      },

      step5: {
        badge: 'STEP 5',
        badgeLabel: 'Enterprise long-term memory · beyond one pipeline',
        title: 'Lift the marketing pipeline into enterprise memory. The AI becomes a coworker.',
        desc: 'AI without memory = tool. AI with memory = coworker. Marketing is only the first pipeline — Step 5 unifies employees, knowledge base and business state into one memory layer that every pipeline shares.',
        inputs: [
          {
            tag: 'PER-EMPLOYEE',
            title: 'Per-employee memory',
            items: ["Each person's work history / preferences / skill map", 'Recurring mistakes + feedback loop', 'All docs / code / chats from the last 3 months', 'Who is good at what, who is not'],
          },
          {
            tag: 'COMPANY KNOWLEDGE',
            title: 'Company knowledge memory',
            items: ['All Notion / Confluence / Drive docs', 'Slack / Feishu history + decision context', 'Customer / project / process SOPs', 'Brand tone / compliance rules / internal lingo'],
          },
          {
            tag: 'BUSINESS STATE',
            title: 'Business state memory',
            items: ['Current OKRs / quarterly progress', 'KPI history + anomalies', 'Customer lifecycle / renewal risk', 'Team bandwidth / schedule / blockers'],
          },
        ],
        brainLabel: 'AI BRAIN',
        outputs: [
          { icon: '📅', title: 'Auto-schedules work', example: '"Wang has 2 POs this week — matched him with 2 AI assistants for doc-writing and translation."' },
          { icon: '🔄', title: 'Dynamically adjusts', example: '"Client X slipped — I moved the deck deadline for the designer and pinged the PM."' },
          { icon: '✉️', title: 'Generates content', example: '"Drafted the renewal proposal for Client Y in our tone, reusing the Q3 win case."' },
          { icon: '🎯', title: 'Flags decisions', example: '"3 renewal customers dropped engagement + a competitor RFP landed — CSM should step in."' },
        ],
        servicePill: { label: 'Metatree delivers', value: 'Enterprise Memory Platform · Hermes Agent', href: '/services/digital-employee/' },
      },

      whereHeading: '/ Where are you stuck right now?',
      whereDesc: '99% of teams are stuck at Step 1. Our job is not to teleport you to Step 5 — it is to move you from your current step to the next one. Every move is a concrete service.',
      whereSteps: [
        { step: 'STEP 1 → 2', from: 'Hand-written posts', to: 'Templated weekly auto-run', service: 'Claude Cowork Setup', duration: '1-2 weeks' },
        { step: 'STEP 2 → 3', from: 'Templated', to: '5-layer pipeline + auto-topic', service: 'AI Agent Workflow Automation', duration: '2-4 weeks' },
        { step: 'STEP 3 → 3.5', from: '4 parallel platform pipelines', to: 'Master/Variant single source', service: 'Custom LLM Applications', duration: '3-5 weeks' },
        { step: 'STEP 3.5 → 4', from: 'Manual weight tuning', to: 'Self-improving feedback loop', service: 'Hermes Agent Implementation', duration: '1-3 weeks' },
        { step: 'STEP 4 → 5', from: 'One pipeline', to: 'Enterprise memory across many', service: 'Enterprise Memory Platform', duration: '4-8 weeks' },
      ],
      whereTable: ['Move', 'From', 'To', 'Metatree delivers', 'Cycle'],

      proofHeading: '/ This is not slideware — we run it every day',
      proofItems: [
        { label: 'Source case', text: 'JR Academy (Metatree\'s parent) — Master/Variant architecture + /master-author /xhs-variant /linkedin-variant /mp-variant /imagery-adapter /publisher (6 Claude Skills), running daily.' },
        { label: 'Content output', text: 'From 1 person × 4 hours hand-writing 4 posts, to 1 person × 30 min running 4 platforms × 12 posts. 3× output at 1/8 the time.' },
        { label: 'Feedback loop', text: '6h / 24h / 7d engagement metrics flow back to Master. AI learns "which hook works where." The next post is data-driven.' },
        { label: 'Portable', text: 'These Claude Skills are files, not SaaS. Drop them into your Claude Cowork — your team owns them. Nobody walks out the door with them.' },
      ],

      ctaHeading: '/ 30-min playbook session',
      ctaBody: 'We look at where you are stuck, which pipeline you need, what feedback loop matters most. You leave with a concrete 4-week ramp plan.',
      ctaButton: 'Book →',
      ctaButtonHref: '/contact/',
    };

const description = locale === 'zh'
  ? 'AI Marketing playbook：从手写 1 条小红书 → 自动跑 4 平台 → Master/Variant → 反馈闭环 → 企业记忆。匠人学院真实跑通的 marketing pipeline，4 步演进 + Step 5 终态。每一步对应 Metatree 一个交付 service。'
  : 'AI Marketing playbook: from one hand-written Xiaohongshu post to a self-improving 4-platform pipeline plus enterprise memory. The actual pipeline JR Academy runs daily — five concrete steps, each mapped to a Metatree service.';
---

<BaseLayout
  title={copy.title}
  description={description}
  locale={locale}
  path={Astro.url.pathname}
>
  <PageHero
    sectionLabel={copy.sectionLabel}
    title={copy.title}
    subtitle={copy.subtitle}
    variant="split"
    eyebrow={copy.eyebrow}
    metaItems={copy.heroMeta}
    railItems={copy.heroRail}
  />

  <!-- THESIS -->
  <section class="pb-thesis">
    <div class="pb-thesis__inner container-x">
      <span class="section-label">{copy.thesisLabel}</span>
      <blockquote class="pb-thesis__quote">{copy.thesisQuote}</blockquote>
      <p class="pb-thesis__body">{copy.thesisBody}</p>
    </div>
  </section>

  <!-- STEPS INTRO -->
  <section class="pb-intro">
    <div class="pb-intro__inner container-x">
      <span class="section-label">{copy.stepsHeading}</span>
      <p class="pb-intro__desc">{copy.stepsDesc}</p>
    </div>
  </section>

  <!-- STEP 1 -->
  <section class="pb-step pb-step--1">
    <div class="pb-step__inner container-x">
      <div class="pb-step__head">
        <span class="pb-step__badge">{copy.step1.badge} · {copy.step1.badgeLabel}</span>
        <h2 class="pb-step__title">{copy.step1.title}</h2>
        <p class="pb-step__desc">{copy.step1.desc}</p>
      </div>

      <div class="pb-flow">
        {copy.step1.flow.map((n, i) => (
          <Fragment>
            <div class="pb-flow__node">
              <div class="pb-flow__icon">{n.icon}</div>
              <div class="pb-flow__label">{n.label}</div>
              <div class="pb-flow__detail">{n.detail}</div>
            </div>
            {i < copy.step1.flow.length - 1 && <span class="pb-flow__arrow">→</span>}
          </Fragment>
        ))}
      </div>

      <div class="pb-stats">
        {copy.step1.stats.map((s) => (
          <div class="pb-stat">
            <span class="pb-stat__label">{s.label}</span>
            <span class="pb-stat__value">{s.value}</span>
          </div>
        ))}
      </div>

      <p class="pb-step__hook">↓ {copy.step1.hookLine}</p>
    </div>
  </section>

  <!-- STEP 2 -->
  <section class="pb-step pb-step--2">
    <div class="pb-step__inner container-x">
      <div class="pb-step__head">
        <span class="pb-step__badge pb-step__badge--accent">{copy.step2.badge} · {copy.step2.badgeLabel}</span>
        <h2 class="pb-step__title">{copy.step2.title}</h2>
        <p class="pb-step__desc">{copy.step2.desc}</p>
      </div>

      <div class="pb-pipeline pb-pipeline--5col">
        {copy.step2.stages.map((s, i) => (
          <Fragment>
            <div class="pb-pipeline__stage">
              <span class="pb-pipeline__tag">{s.tag}</span>
              <h3 class="pb-pipeline__title">{s.title}</h3>
              <p class="pb-pipeline__detail">{s.detail}</p>
              <span class="pb-pipeline__index">0{i + 1}</span>
            </div>
            {i < copy.step2.stages.length - 1 && <span class="pb-pipeline__arrow">→</span>}
          </Fragment>
        ))}
      </div>

      <div class="pb-compare">
        <div class="pb-compare__col pb-compare__col--before">
          <span class="pb-compare__tag">BEFORE · STEP 1</span>
          <p>{copy.step2.before}</p>
        </div>
        <div class="pb-compare__col pb-compare__col--after">
          <span class="pb-compare__tag">NOW · STEP 2</span>
          <p>{copy.step2.after}</p>
        </div>
      </div>

      {copy.step2.servicePill && (
        <a href={localizedHref(copy.step2.servicePill.href, locale)} class="pb-pill">
          <span class="pb-pill__label">{copy.step2.servicePill.label}</span>
          <span class="pb-pill__value">{copy.step2.servicePill.value}</span>
          <span class="pb-pill__arrow">→</span>
        </a>
      )}
    </div>
  </section>

  <!-- STEP 3 -->
  <section class="pb-step pb-step--3">
    <div class="pb-step__inner container-x">
      <div class="pb-step__head">
        <span class="pb-step__badge pb-step__badge--accent">{copy.step3.badge} · {copy.step3.badgeLabel}</span>
        <h2 class="pb-step__title">{copy.step3.title}</h2>
        <p class="pb-step__desc">{copy.step3.desc}</p>
      </div>

      <div class="pb-layers">
        {copy.step3.layers.map((layer) => (
          <div class="pb-layer">
            <div class="pb-layer__head">
              <span class="pb-layer__tag">LAYER {layer.tag}</span>
              <h3 class="pb-layer__title">{layer.tagLabel}</h3>
              <span class="pb-layer__skill">SKILL · {layer.skill}</span>
            </div>
            <div class="pb-layer__nodes">
              {layer.nodes.map((n) => (
                <div class="pb-layer__node">
                  <span class="pb-layer__node-name">{n.label}</span>
                  {n.hint && <span class="pb-layer__node-hint">{n.hint}</span>}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="pb-signature">{copy.step3.signature}</div>

      {copy.step3.servicePill && (
        <a href={localizedHref(copy.step3.servicePill.href, locale)} class="pb-pill">
          <span class="pb-pill__label">{copy.step3.servicePill.label}</span>
          <span class="pb-pill__value">{copy.step3.servicePill.value}</span>
          <span class="pb-pill__arrow">→</span>
        </a>
      )}
    </div>
  </section>

  <!-- STEP 3.5 — Master / Variant -->
  <section class="pb-step pb-step--35">
    <div class="pb-step__inner container-x">
      <div class="pb-step__head">
        <span class="pb-step__badge pb-step__badge--flagship">{copy.step35.badge} · {copy.step35.badgeLabel}</span>
        <h2 class="pb-step__title">{copy.step35.title}</h2>
        <p class="pb-step__desc">{copy.step35.desc}</p>
      </div>

      <div class="pb-mv">
        <!-- Master -->
        <div class="pb-mv__master">
          <span class="pb-mv__layer">{copy.step35.master.layer}</span>
          <h3 class="pb-mv__master-title">📄 {copy.step35.master.name}</h3>
          <ul class="pb-mv__list">
            {copy.step35.master.detail.map((d) => <li>· {d}</li>)}
          </ul>
          <div class="pb-mv__skill">
            <span class="pb-mv__skill-label">SKILL</span>
            <span class="pb-mv__skill-value">{copy.step35.master.skill}</span>
          </div>
          <span class="pb-mv__truth">{copy.step35.master.tagline}</span>
        </div>

        <!-- Variants -->
        <div class="pb-mv__variants">
          <span class="pb-mv__layer">{copy.step35.variantsLayer}</span>
          {copy.step35.variants.map((v) => (
            <div class="pb-mv__variant">
              <div class="pb-mv__variant-id">
                <span class="pb-mv__variant-icon">{v.icon}</span>
                <span class="pb-mv__variant-name">{v.name}</span>
                <span class="pb-mv__variant-skill">{v.skill}</span>
              </div>
              <div class="pb-mv__variant-spec">
                <span class="pb-mv__spec-label">TEXT</span>
                <span>{v.text}</span>
              </div>
              <div class="pb-mv__variant-spec">
                <span class="pb-mv__spec-label">IMAGE</span>
                <span>{v.image}</span>
              </div>
            </div>
          ))}
        </div>

        <!-- Publish -->
        <div class="pb-mv__publish">
          <span class="pb-mv__layer">{copy.step35.publish.layer}</span>
          <h3 class="pb-mv__publish-title">🚀 {copy.step35.publish.name}</h3>
          <ul class="pb-mv__list">
            {copy.step35.publish.detail.map((d) => <li>· {d}</li>)}
          </ul>
          <div class="pb-mv__skill">
            <span class="pb-mv__skill-label">SKILL</span>
            <span class="pb-mv__skill-value">{copy.step35.publish.skill}</span>
          </div>
        </div>
      </div>

      <div class="pb-mv__footer">
        <div class="pb-mv__feedback">
          <span class="pb-mv__feedback-badge">{copy.step35.feedbackBadge}</span>
          <span>{copy.step35.feedbackText}</span>
        </div>
        <div class="pb-mv__vs">
          <span class="pb-mv__vs-badge">{copy.step35.vsBadge}</span>
          <span>{copy.step35.vsText}</span>
        </div>
      </div>

      {copy.step35.servicePill && (
        <a href={localizedHref(copy.step35.servicePill.href, locale)} class="pb-pill">
          <span class="pb-pill__label">{copy.step35.servicePill.label}</span>
          <span class="pb-pill__value">{copy.step35.servicePill.value}</span>
          <span class="pb-pill__arrow">→</span>
        </a>
      )}
    </div>
  </section>

  <!-- STEP 4 — full pipeline + feedback loop -->
  <section class="pb-step pb-step--4">
    <div class="pb-step__inner container-x">
      <div class="pb-step__head">
        <span class="pb-step__badge pb-step__badge--accent">{copy.step4.badge} · {copy.step4.badgeLabel}</span>
        <h2 class="pb-step__title">{copy.step4.title}</h2>
        <p class="pb-step__desc">{copy.step4.desc}</p>
      </div>

      <div class="pb-loop">
        <div class="pb-loop__cycle">
          {copy.step4.nodes.map((n, i) => (
            <Fragment>
              <div class="pb-loop__node">
                <span class="pb-loop__num">0{i + 1}</span>
                <span class="pb-loop__label">{n.label}</span>
                <span class="pb-loop__sub">{n.sub}</span>
              </div>
              {i < copy.step4.nodes.length - 1 && <span class="pb-loop__arrow">↻</span>}
            </Fragment>
          ))}
        </div>
        <div class="pb-loop__hub">
          <span class="pb-loop__hub-tag">{copy.step4.feedbackHubLabel}</span>
          <span class="pb-loop__hub-name">{copy.step4.feedbackHubName}</span>
          <span class="pb-loop__hub-detail">{copy.step4.feedbackHubDetail}</span>
        </div>
      </div>

      <div class="pb-compare-grid">
        {copy.step4.compare.map((c, i) => (
          <div class={`pb-compare-card pb-compare-card--${i === 0 ? 'before' : 'after'}`}>
            <span class="pb-compare-card__side">{c.side}</span>
            <h3 class="pb-compare-card__team">{c.team}</h3>
            <ul class="pb-compare-card__list">
              {c.detail.map((d) => <li>· {d}</li>)}
            </ul>
            <div class="pb-compare-card__metrics">
              <div class="pb-compare-card__metric">
                <span class="pb-compare-card__metric-label">TIME</span>
                <span class="pb-compare-card__metric-value">{c.time}</span>
              </div>
              <div class="pb-compare-card__metric">
                <span class="pb-compare-card__metric-label">OUTPUT</span>
                <span class="pb-compare-card__metric-value">{c.output}</span>
              </div>
            </div>
          </div>
        ))}
      </div>

      {copy.step4.servicePill && (
        <a href={localizedHref(copy.step4.servicePill.href, locale)} class="pb-pill">
          <span class="pb-pill__label">{copy.step4.servicePill.label}</span>
          <span class="pb-pill__value">{copy.step4.servicePill.value}</span>
          <span class="pb-pill__arrow">→</span>
        </a>
      )}
    </div>
  </section>

  <!-- STEP 5 — Enterprise Memory -->
  <section class="pb-step pb-step--5">
    <div class="pb-step__inner container-x">
      <div class="pb-step__head">
        <span class="pb-step__badge pb-step__badge--flagship">{copy.step5.badge} · {copy.step5.badgeLabel}</span>
        <h2 class="pb-step__title">{copy.step5.title}</h2>
        <p class="pb-step__desc">{copy.step5.desc}</p>
      </div>

      <div class="pb-mem">
        <div class="pb-mem__col pb-mem__col--inputs">
          <span class="section-label">INPUT · 3 LAYERS</span>
          {copy.step5.inputs.map((input) => (
            <div class="pb-mem__input">
              <span class="pb-mem__input-tag">{input.tag}</span>
              <h4 class="pb-mem__input-title">{input.title}</h4>
              <ul class="pb-mem__list">
                {input.items.map((it) => <li>· {it}</li>)}
              </ul>
            </div>
          ))}
        </div>

        <div class="pb-mem__brain" aria-hidden="true">
          <div class="pb-brain">
            <span class="pb-brain__label">{copy.step5.brainLabel}</span>
          </div>
        </div>

        <div class="pb-mem__col pb-mem__col--outputs">
          <span class="section-label">OUTPUT · 4 ACTIONS</span>
          {copy.step5.outputs.map((output) => (
            <div class="pb-mem__output">
              <div class="pb-mem__output-top">
                <span class="pb-mem__output-icon">{output.icon}</span>
                <h4 class="pb-mem__output-title">{output.title}</h4>
              </div>
              <p class="pb-mem__output-example">{output.example}</p>
            </div>
          ))}
        </div>
      </div>

      {copy.step5.servicePill && (
        <a href={localizedHref(copy.step5.servicePill.href, locale)} class="pb-pill">
          <span class="pb-pill__label">{copy.step5.servicePill.label}</span>
          <span class="pb-pill__value">{copy.step5.servicePill.value}</span>
          <span class="pb-pill__arrow">→</span>
        </a>
      )}
    </div>
  </section>

  <!-- WHERE ARE YOU STUCK -->
  <section class="pb-where">
    <div class="pb-where__inner container-x">
      <span class="section-label">{copy.whereHeading}</span>
      <p class="pb-where__desc">{copy.whereDesc}</p>

      <div class="pb-where__table" role="table">
        <div class="pb-where__row pb-where__row--head" role="row">
          {copy.whereTable.map((h) => (
            <span class="pb-where__cell pb-where__cell--head" role="columnheader">{h}</span>
          ))}
        </div>
        {copy.whereSteps.map((row) => (
          <div class="pb-where__row" role="row">
            <span class="pb-where__cell pb-where__cell--step" role="cell">{row.step}</span>
            <span class="pb-where__cell" role="cell">{row.from}</span>
            <span class="pb-where__cell" role="cell">{row.to}</span>
            <span class="pb-where__cell pb-where__cell--service" role="cell">{row.service}</span>
            <span class="pb-where__cell pb-where__cell--duration" role="cell">{row.duration}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROOF -->
  <section class="pb-proof">
    <div class="pb-proof__inner container-x">
      <span class="section-label">{copy.proofHeading}</span>
      <div class="pb-proof__grid">
        {copy.proofItems.map((item) => (
          <div class="pb-proof__card">
            <span class="pb-proof__label">{item.label}</span>
            <p class="pb-proof__text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-cta">
    <div class="pb-cta__inner container-x">
      <div class="pb-cta__card">
        <div class="pb-cta__body">
          <span class="section-label">{copy.ctaHeading}</span>
          <p class="pb-cta__text">{copy.ctaBody}</p>
        </div>
        <a href={localizedHref(copy.ctaButtonHref, locale)} class="btn-primary pb-cta__btn">{copy.ctaButton}</a>
      </div>
    </div>
  </section>

  <EngagementModes locale={locale} />
  <CtaFooter locale={locale} />
</BaseLayout>

<style>
  /* SHARED */
  .pb-thesis,
  .pb-intro,
  .pb-step,
  .pb-where,
  .pb-proof,
  .pb-cta {
    position: relative;
    z-index: 2;
  }

  .pb-step {
    padding-block: var(--space-8);
    border-top: 1px solid var(--border-hairline);
  }

  .pb-step__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .pb-step__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: 96rem;
  }

  .pb-step__badge {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: 0.12em;
    color: var(--text-tertiary);
    text-transform: uppercase;
    align-self: flex-start;
    padding: 4px 10px;
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-sm);
    background: rgba(0, 0, 0, 0.4);
  }

  .pb-step__badge--accent {
    color: var(--brand-primary);
    border-color: var(--brand-primary);
    background: rgba(0, 229, 160, 0.08);
  }

  .pb-step__badge--flagship {
    color: var(--brand-accent);
    border-color: var(--brand-accent);
    background: linear-gradient(90deg, rgba(0, 229, 160, 0.18), rgba(0, 180, 216, 0.12));
  }

  .pb-step__title {
    font-size: var(--fs-h2);
    font-weight: var(--fw-bold);
    letter-spacing: -0.02em;
    line-height: var(--lh-snug);
    color: var(--text-primary);
  }

  .pb-step__desc {
    font-size: var(--fs-body-lg);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
    max-width: 80rem;
  }

  /* THESIS */
  .pb-thesis {
    padding-block: var(--space-8);
  }
  .pb-thesis__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 100rem;
  }
  .pb-thesis__quote {
    font-size: var(--fs-h2);
    font-weight: var(--fw-bold);
    letter-spacing: -0.02em;
    line-height: var(--lh-snug);
    color: var(--text-primary);
    border-left: 3px solid var(--brand-primary);
    padding-left: var(--space-4);
    margin: 0;
  }
  .pb-thesis__body {
    font-size: var(--fs-body-lg);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
    max-width: 80rem;
  }

  /* INTRO */
  .pb-intro {
    padding-block: var(--space-5) var(--space-3);
    border-top: 1px solid var(--border-hairline);
  }
  .pb-intro__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .pb-intro__desc {
    font-size: var(--fs-body-lg);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
    max-width: 96rem;
  }

  /* STEP 1 — flow */
  .pb-flow {
    display: flex;
    align-items: stretch;
    gap: var(--space-2);
  }
  .pb-flow__node {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-2);
    padding: var(--space-4);
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-md);
    background: var(--bg-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .pb-flow__icon {
    font-size: 3.6rem;
    line-height: 1;
  }
  .pb-flow__label {
    font-weight: var(--fw-bold);
    font-size: var(--fs-body-lg);
    color: var(--text-primary);
  }
  .pb-flow__detail {
    font-family: var(--font-mono);
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
  }
  .pb-flow__arrow {
    align-self: center;
    font-family: var(--font-mono);
    font-size: var(--fs-h3);
    color: var(--text-tertiary);
  }

  .pb-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-2);
  }
  .pb-stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-4);
    border: 2px solid var(--border-strong);
    border-radius: var(--radius-sm);
    background: rgba(0, 0, 0, 0.4);
  }
  .pb-stat__label {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: 0.12em;
    color: var(--text-tertiary);
    text-transform: uppercase;
  }
  .pb-stat__value {
    font-size: var(--fs-body);
    font-weight: var(--fw-bold);
    color: var(--text-primary);
  }

  .pb-step__hook {
    align-self: flex-start;
    margin: var(--space-2) 0 0;
    padding: var(--space-3) var(--space-5);
    background: var(--brand-primary);
    color: #000;
    font-weight: var(--fw-bold);
    font-size: var(--fs-body-lg);
    border-radius: var(--radius-sm);
  }

  /* STEP 2 — 5-stage pipeline */
  .pb-pipeline {
    display: flex;
    align-items: stretch;
    gap: var(--space-2);
  }
  .pb-pipeline__stage {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-md);
    background: var(--bg-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    position: relative;
    min-height: 18rem;
  }
  .pb-pipeline__tag {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: 0.12em;
    color: var(--brand-primary);
    text-transform: uppercase;
    padding: 2px 6px;
    background: rgba(0, 229, 160, 0.12);
    border: 1px solid var(--brand-primary);
    border-radius: var(--radius-sm);
    align-self: flex-start;
  }
  .pb-pipeline__title {
    font-size: var(--fs-body-lg);
    font-weight: var(--fw-bold);
    color: var(--text-primary);
  }
  .pb-pipeline__detail {
    font-family: var(--font-mono);
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
  }
  .pb-pipeline__index {
    margin-top: auto;
    font-family: var(--font-mono);
    font-size: var(--fs-h4);
    font-weight: var(--fw-bold);
    color: var(--brand-primary);
  }
  .pb-pipeline__arrow {
    align-self: center;
    font-family: var(--font-mono);
    font-size: var(--fs-h4);
    color: var(--text-tertiary);
  }

  .pb-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .pb-compare__col {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .pb-compare__col--before {
    background: rgba(255, 80, 80, 0.06);
    border-right: 1px solid var(--border-hairline);
  }
  .pb-compare__col--after {
    background: rgba(0, 229, 160, 0.06);
  }
  .pb-compare__tag {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: 0.12em;
  }
  .pb-compare__col--before .pb-compare__tag { color: #ff8080; }
  .pb-compare__col--after .pb-compare__tag { color: var(--brand-primary); }
  .pb-compare__col p {
    font-size: var(--fs-body);
    font-weight: var(--fw-medium);
    color: var(--text-primary);
  }

  /* STEP 3 — 5 horizontal layers */
  .pb-layers {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .pb-layer {
    display: grid;
    grid-template-columns: 22rem 1fr;
    gap: 0;
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .pb-layer__head {
    background: linear-gradient(135deg, rgba(0, 229, 160, 0.12), rgba(0, 180, 216, 0.08));
    padding: var(--space-3) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    justify-content: center;
    border-right: 1px solid var(--border-hairline);
  }
  .pb-layer__tag {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: 0.12em;
    color: var(--brand-primary);
    text-transform: uppercase;
  }
  .pb-layer__title {
    font-size: var(--fs-body-lg);
    font-weight: var(--fw-bold);
    color: var(--text-primary);
  }
  .pb-layer__skill {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    color: var(--brand-accent);
    background: rgba(0, 0, 0, 0.5);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    align-self: flex-start;
  }
  .pb-layer__nodes {
    display: flex;
    align-items: stretch;
    gap: var(--space-2);
    padding: var(--space-3);
    flex-wrap: wrap;
  }
  .pb-layer__node {
    flex: 1 1 16rem;
    min-width: 14rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-sm);
    background: rgba(0, 0, 0, 0.4);
  }
  .pb-layer__node-name {
    font-weight: var(--fw-bold);
    font-size: var(--fs-body-sm);
    color: var(--text-primary);
  }
  .pb-layer__node-hint {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    color: var(--text-tertiary);
  }

  .pb-signature {
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: 0.16em;
    color: var(--brand-primary);
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--brand-primary);
    border-radius: var(--radius-sm);
    background: rgba(0, 229, 160, 0.08);
    text-transform: uppercase;
  }

  /* STEP 3.5 — Master/Variant */
  .pb-mv {
    display: grid;
    grid-template-columns: 22rem 1fr 18rem;
    gap: var(--space-3);
    align-items: stretch;
  }
  .pb-mv__layer {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: 0.12em;
    color: var(--brand-accent);
    text-transform: uppercase;
  }
  .pb-mv__master {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    border: 2px solid var(--brand-primary);
    border-radius: var(--radius-md);
    background: linear-gradient(180deg, rgba(0, 229, 160, 0.1), rgba(0, 0, 0, 0.5));
  }
  .pb-mv__master-title {
    font-size: var(--fs-h3);
    font-weight: var(--fw-bold);
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }
  .pb-mv__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .pb-mv__list li {
    font-family: var(--font-mono);
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
  }
  .pb-mv__skill {
    margin-top: var(--space-2);
    padding: var(--space-2);
    background: rgba(0, 0, 0, 0.5);
    border-left: 3px solid var(--brand-primary);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .pb-mv__skill-label {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: 0.12em;
    color: var(--brand-primary);
  }
  .pb-mv__skill-value {
    font-family: var(--font-mono);
    font-size: var(--fs-body-sm);
    color: var(--text-primary);
    font-weight: var(--fw-bold);
  }
  .pb-mv__truth {
    margin-top: auto;
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: 0.12em;
    color: #000;
    background: var(--brand-primary);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
  }

  .pb-mv__variants {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .pb-mv__variant {
    display: grid;
    grid-template-columns: 12rem 1fr 1fr;
    gap: 0;
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-sm);
    background: var(--bg-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    overflow: hidden;
  }
  .pb-mv__variant-id {
    padding: var(--space-2) var(--space-3);
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: rgba(0, 0, 0, 0.4);
    border-right: 1px solid var(--border-hairline);
  }
  .pb-mv__variant-icon {
    font-size: 2.4rem;
    line-height: 1;
  }
  .pb-mv__variant-name {
    font-weight: var(--fw-bold);
    color: var(--text-primary);
  }
  .pb-mv__variant-skill {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    color: var(--brand-accent);
  }
  .pb-mv__variant-spec {
    padding: var(--space-2) var(--space-3);
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-right: 1px dashed var(--border-hairline);
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
  }
  .pb-mv__variant-spec:last-child {
    border-right: 0;
  }
  .pb-spec-label,
  .pb-mv__spec-label {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: 0.12em;
    color: var(--text-tertiary);
  }

  .pb-mv__publish {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    border: 1px solid var(--brand-secondary);
    border-radius: var(--radius-md);
    background: linear-gradient(180deg, rgba(0, 180, 216, 0.1), rgba(0, 0, 0, 0.5));
  }
  .pb-mv__publish-title {
    font-size: var(--fs-h4);
    font-weight: var(--fw-bold);
    color: var(--text-primary);
  }

  .pb-mv__footer {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  .pb-mv__feedback,
  .pb-mv__vs {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-3);
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-md);
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
  }
  .pb-mv__feedback {
    background: rgba(0, 0, 0, 0.5);
  }
  .pb-mv__vs {
    background: rgba(0, 229, 160, 0.06);
  }
  .pb-mv__feedback-badge,
  .pb-mv__vs-badge {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: 0.12em;
    color: #000;
    background: var(--brand-primary);
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .pb-mv__vs-badge {
    background: var(--brand-accent);
  }

  /* STEP 4 — loop + compare */
  .pb-loop {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    padding: var(--space-5);
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-md);
    background: var(--bg-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .pb-loop__cycle {
    display: flex;
    align-items: stretch;
    gap: var(--space-2);
  }
  .pb-loop__node {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3);
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-sm);
    background: rgba(0, 0, 0, 0.4);
    border-top: 3px solid var(--brand-primary);
  }
  .pb-loop__num {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    color: var(--brand-primary);
    letter-spacing: 0.12em;
  }
  .pb-loop__label {
    font-weight: var(--fw-bold);
    color: var(--text-primary);
  }
  .pb-loop__sub {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    color: var(--text-tertiary);
  }
  .pb-loop__arrow {
    align-self: center;
    font-family: var(--font-mono);
    color: var(--brand-primary);
    font-size: var(--fs-h4);
  }
  .pb-loop__hub {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
    background: linear-gradient(90deg, rgba(0, 229, 160, 0.18), rgba(0, 180, 216, 0.12));
    border: 1px dashed var(--brand-primary);
    border-radius: var(--radius-md);
  }
  .pb-loop__hub-tag {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    color: #000;
    background: var(--brand-accent);
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    letter-spacing: 0.12em;
  }
  .pb-loop__hub-name {
    font-weight: var(--fw-bold);
    color: var(--text-primary);
    font-size: var(--fs-body-lg);
  }
  .pb-loop__hub-detail {
    font-family: var(--font-mono);
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
  }

  .pb-compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  .pb-compare-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-hairline);
  }
  .pb-compare-card--before {
    background: linear-gradient(180deg, rgba(255, 80, 80, 0.08), rgba(0, 0, 0, 0.4));
  }
  .pb-compare-card--after {
    background: linear-gradient(180deg, rgba(0, 229, 160, 0.1), rgba(0, 0, 0, 0.4));
    border-color: var(--brand-primary);
  }
  .pb-compare-card__side {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: 0.12em;
    align-self: flex-start;
  }
  .pb-compare-card--before .pb-compare-card__side { color: #ff8080; }
  .pb-compare-card--after .pb-compare-card__side { color: var(--brand-primary); }
  .pb-compare-card__team {
    font-size: var(--fs-h4);
    font-weight: var(--fw-bold);
    color: var(--text-primary);
  }
  .pb-compare-card__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .pb-compare-card__list li {
    font-family: var(--font-mono);
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
  }
  .pb-compare-card__metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }
  .pb-compare-card__metric {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-sm);
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .pb-compare-card__metric-label {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: 0.12em;
    color: var(--text-tertiary);
  }
  .pb-compare-card__metric-value {
    font-weight: var(--fw-bold);
    color: var(--text-primary);
  }

  /* STEP 5 — Memory architecture */
  .pb-mem {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-4);
    align-items: start;
  }
  .pb-mem__col {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .pb-mem__input,
  .pb-mem__output {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-hairline);
    background: var(--bg-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .pb-mem__input {
    border-left: 3px solid var(--brand-primary);
  }
  .pb-mem__output {
    border-left: 3px solid var(--brand-secondary);
    background: rgba(0, 0, 0, 0.5);
  }
  .pb-mem__input-tag {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: 0.12em;
    color: var(--brand-primary);
  }
  .pb-mem__input-title {
    font-size: var(--fs-h4);
    font-weight: var(--fw-bold);
    color: var(--text-primary);
  }
  .pb-mem__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .pb-mem__list li {
    font-family: var(--font-mono);
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
  }
  .pb-mem__output-top {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .pb-mem__output-icon {
    font-size: 2rem;
    line-height: 1;
  }
  .pb-mem__output-title {
    font-size: var(--fs-h4);
    font-weight: var(--fw-bold);
