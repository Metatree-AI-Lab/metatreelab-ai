---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../ui/PageHero.astro';
import EngagementModes from '../home/EngagementModes.astro';
import CtaFooter from '../shared/CtaFooter.astro';
import { localizedHref, type Locale } from '../../config/site';
import { services, servicesByTrack } from '../../data/services';
import { buildItemList, buildService } from '../../lib/schema';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const copy = locale === 'zh'
  ? {
      sectionLabel: '/ SERVICES',
      title: 'AI 咨询与数字营销服务。',
      subtitle: '从 AI Agent 搭建到房产营销全栈 — 每条业务线都有真实项目作为证据。',
      buildLabel: '/ A1 — AI · BUILD',
      adoptLabel: '/ A2 — AI · ADOPT',
      digitalEmployeeLabel: '/ B — AI DIGITAL EMPLOYEE',
      propertyLabel: '/ C — PROPERTY',
      buildTitle: 'AI Build Track',
      adoptTitle: 'AI Adopt Track',
      digitalEmployeeTitle: 'AI Digital Employee',
      propertyTitle: 'Property Marketing',
      buildDesc: '定制 AI 开发：战略、RAG、Agent、LLM 应用、平台工程。单价高、周期长、需要工程师深度参与。',
      adoptDesc: '把 AI 装进你的团队：Claude Cowork 搭建、OpenClaw 🦞、工作流自动化、员工培训。短周期、量大、现金流引擎。',
      digitalEmployeeDesc: '企业级数字员工：三层记忆系统 + 跨 agent 共享大脑 + 多渠道部署。入职一次、永久记忆、越用越聪明。',
      propertyDesc: '澳洲房地产营销全栈：开发商主站、楼盘专属页、品牌视觉、广告着陆页、长期 retainer。',
      explore: '查看全部服务',
      title_b: '了解 Property 服务',
      brainEyebrow: 'PLAYBOOK · 4 步演进 + Step 5 企业记忆',
      brainLabel: '/ AI MARKETING PLAYBOOK',
      brainTitle: '从手写 1 条小红书 → 自动跑 4 平台的 marketing pipeline',
      brainDesc: '匠人学院真实在跑的 marketing pipeline，4 步演进 + Step 5 企业级长期记忆。6 个 Claude Skill、Master/Variant 架构、反馈闭环 — 每一步都对应 Metatree 一个交付 service。',
      brainCta: '看 playbook →',
    }
  : {
      sectionLabel: '/ SERVICES',
      title: 'AI Consulting & Digital Marketing Services.',
      subtitle: 'From AI agent development to property marketing — every service line is backed by real shipped projects.',
      buildLabel: '/ A1 — AI · BUILD',
      adoptLabel: '/ A2 — AI · ADOPT',
      digitalEmployeeLabel: '/ B — AI DIGITAL EMPLOYEE',
      propertyLabel: '/ C — PROPERTY',
      buildTitle: 'AI Build Track',
      adoptTitle: 'AI Adopt Track',
      digitalEmployeeTitle: 'AI Digital Employee',
      propertyTitle: 'Property Marketing',
      buildDesc: 'Custom AI engineering: strategy, RAG, agents, LLM apps, platform engineering. High ticket, long cycle, heavy engineering involvement.',
      adoptDesc: 'Install AI into your team: Claude Cowork setup, OpenClaw 🦞, workflow automation, enablement training. Short cycle, high volume, cashflow engine.',
      digitalEmployeeDesc: 'Enterprise-grade digital employee: three-layer memory system + shared brain across agents + multi-channel deployment. Onboard once, remember forever, gets sharper daily.',
      propertyDesc: 'Full-stack property marketing for Australia: developer websites, single-project landing pages, brand identity, ad pages, ongoing retainers.',
      explore: 'Explore all services',
      title_b: 'Explore Property services',
      brainEyebrow: 'PLAYBOOK · 4-step ramp + Step 5 enterprise memory',
      brainLabel: '/ AI MARKETING PLAYBOOK',
      brainTitle: 'From 1 hand-written Xiaohongshu post to a 4-platform pipeline that runs itself',
      brainDesc: 'The exact marketing pipeline JR Academy runs daily — 4 evolution steps + Step 5 enterprise long-term memory. 6 Claude Skills, Master/Variant architecture, learning loop. Every step maps to a Metatree delivery.',
      brainCta: 'See playbook →',
    };

const tracks = [
  {
    label: copy.buildLabel,
    title: copy.buildTitle,
    desc: copy.buildDesc,
    services: servicesByTrack.build,
    href: localizedHref('/services/ai/', locale),
    accent: 'jade',
  },
  {
    label: copy.adoptLabel,
    title: copy.adoptTitle,
    desc: copy.adoptDesc,
    services: servicesByTrack.adopt,
    href: localizedHref('/services/ai/', locale),
    accent: 'jade',
  },
  {
    label: copy.digitalEmployeeLabel,
    title: copy.digitalEmployeeTitle,
    desc: copy.digitalEmployeeDesc,
    services: servicesByTrack.digitalEmployee,
    href: localizedHref('/services/digital-employee/', locale),
    accent: 'jade',
  },
  {
    label: copy.propertyLabel,
    title: copy.propertyTitle,
    desc: copy.propertyDesc,
    services: servicesByTrack.property,
    href: localizedHref('/services/property/', locale),
    accent: 'white',
  },
];

const description = locale === 'zh'
  ? '4 条业务线、39 项服务：AI 定制开发、AI 落地、AI 数字员工、房产营销。每项服务都有线上产品作为证据。'
  : 'Four service lines, 39 offerings: AI Build, AI Adopt, AI Digital Employee, Property Marketing. Every capability has a live system as proof.';

const servicesSchema = buildItemList(
  locale === 'zh' ? 'Metatree AI Lab — 服务目录' : 'Metatree AI Lab — Service Catalogue',
  services,
  (s) => buildService(s, locale),
);
---

<BaseLayout
  title={copy.title}
  description={description}
  locale={locale}
  path={Astro.url.pathname}
  schema={servicesSchema}
>
  <PageHero
    sectionLabel={copy.sectionLabel}
    title={copy.title}
    subtitle={copy.subtitle}
  />

  <!-- ENTERPRISE BRAIN CALLOUT -->
  <section class="brain-callout">
    <div class="brain-callout__inner container-x">
      <a href={localizedHref('/playbooks/ai-marketing/', locale)} class="brain-callout__card">
        <div class="brain-callout__body">
          <span class="section-label">{copy.brainLabel}</span>
          <p class="brain-callout__eyebrow">{copy.brainEyebrow}</p>
          <h2 class="brain-callout__title">{copy.brainTitle}</h2>
          <p class="brain-callout__desc">{copy.brainDesc}</p>
        </div>
        <span class="brain-callout__cta">{copy.brainCta}</span>
      </a>
    </div>
  </section>

  <section class="tracks">
    <div class="tracks__inner container-x">
      {
        tracks.map((track) => (
          <div class={`tracks__block tracks__block--${track.accent}`}>
            <div class="tracks__head">
              <span class="section-label">{track.label}</span>
              <a href={track.href} class="tracks__cta">
                {copy.explore} →
              </a>
            </div>

            <h2 class="tracks__title">{track.title}</h2>
            <p class="tracks__desc">{track.desc}</p>

            <ul class="tracks__list">
              {track.services.map((s) => (
                <li class={`tracks__item ${s.flagship ? 'tracks__item--flagship' : ''}`}>
                  <div class="tracks__item-head">
                    <span class="tracks__item-name">{s.title[locale]}</span>
                    {s.flagship && <span class="tracks__flagship">FLAGSHIP</span>}
                    <span class="tracks__duration">{s.duration}</span>
                  </div>
                  <p class="tracks__item-sub">{s.subtitle[locale]}</p>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <EngagementModes locale={locale} />
  <CtaFooter locale={locale} />
</BaseLayout>

<style>
  /* ENTERPRISE BRAIN CALLOUT */
  .brain-callout {
    position: relative;
    padding-block: var(--space-6);
    z-index: 2;
  }

  .brain-callout__card {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-6);
    border: 1px solid rgba(0, 229, 160, 0.35);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(135deg, rgba(0, 229, 160, 0.08) 0%, rgba(0, 180, 216, 0.04) 50%, transparent 100%),
      var(--bg-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition: border-color var(--dur-normal) var(--ease-out), transform var(--dur-normal) var(--ease-out);
  }

  .brain-callout__card:hover {
    border-color: var(--brand-primary);
    transform: translateY(-2px);
  }

  .brain-callout__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .brain-callout__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: 0.04em;
    color: var(--brand-secondary);
    text-transform: uppercase;
  }

  .brain-callout__title {
    font-size: var(--fs-h3);
    font-weight: var(--fw-bold);
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: var(--lh-snug);
  }

  .brain-callout__desc {
    font-size: var(--fs-body);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
    max-width: 80rem;
  }

  .brain-callout__cta {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: 0.06em;
    color: var(--brand-primary);
    text-transform: uppercase;
    white-space: nowrap;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--brand-primary);
    border-radius: var(--radius-md);
    transition: background var(--dur-normal) var(--ease-out);
  }

  .brain-callout__card:hover .brain-callout__cta {
    background: rgba(0, 229, 160, 0.12);
  }

  @media (max-width: 767px) {
    .brain-callout__card {
      grid-template-columns: 1fr;
      padding: var(--space-5);
    }
    .brain-callout__title {
      font-size: var(--fs-h4);
    }
  }

  .tracks {
    position: relative;
    padding-block: var(--space-8);
    z-index: 2;
  }

  .tracks__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-9);
  }

  .tracks__block {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-top: var(--space-6);
    border-top: 1px solid var(--border-hairline);
  }

  .tracks__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-2);
  }

  .tracks__cta {
    font-family: var(--font-mono);
    font-size: var(--fs-body-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    transition: color var(--dur-normal) var(--ease-out);
  }

  .tracks__block--jade .tracks__cta:hover {
    color: var(--brand-primary);
  }

  .tracks__block--white .tracks__cta:hover {
    color: var(--text-primary);
  }

  .tracks__title {
    font-size: var(--fs-h2);
    font-weight: var(--fw-bold);
    letter-spacing: -0.02em;
  }

  .tracks__desc {
    font-size: var(--fs-body-lg);
    color: var(--text-secondary);
    max-width: 72rem;
    line-height: var(--lh-normal);
  }

  .tracks__list {
    list-style: none;
    padding: 0;
    margin: var(--space-5) 0 0 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: 1px solid var(--border-hairline);
  }

  .tracks__item {
    padding: var(--space-4) var(--space-5) var(--space-4) 0;
    border-bottom: 1px solid var(--border-hairline);
  }

  .tracks__item:nth-child(odd) {
    border-right: 1px solid var(--border-hairline);
    padding-right: var(--space-5);
  }

  .tracks__item:nth-child(even) {
    padding-left: var(--space-5);
  }

  .tracks__item--flagship {
    background: rgba(0, 229, 160, 0.03);
  }

  .tracks__item-head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .tracks__item-name {
    font-size: var(--fs-h4);
    font-weight: var(--fw-semibold);
    color: var(--text-primary);
    flex: 1;
  }

  .tracks__flagship {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: 0.1em;
    padding: 2px 6px;
    background: rgba(0, 229, 160, 0.1);
    color: var(--brand-primary);
    border: 1px solid var(--brand-primary);
    border-radius: var(--radius-sm);
  }

  .tracks__duration {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .tracks__item-sub {
    font-size: var(--fs-body-sm);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
  }

  @media (max-width: 767px) {
    .tracks__list {
      grid-template-columns: 1fr;
    }
    .tracks__item:nth-child(odd),
    .tracks__item:nth-child(even) {
      border-right: none;
      padding: var(--space-4) 0;
    }
    .tracks__title {
      font-size: var(--fs-h3);
    }
  }
</style>
