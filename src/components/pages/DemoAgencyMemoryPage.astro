        text: { en: 'Send Ms. Zhou the catchment letter and follow up — budget $640K, within vendor’s acceptable range', zh: '给周小姐发学区证明并回访——预算 $640K，已落在业主可接受区间' },
        why: { en: 'Hot first-home buyer; budget meets the vendor’s $640K floor — closeable', zh: '热门首房买家，预算正好达业主 $640K 底线，可促成' },
      },
      {
        to: { en: 'Agent', zh: '中介' }, level: 'normal',
        text: { en: 'Send Mr. Huang the strata report with current rent & vacancy figures', zh: '给黄先生发物业报告，附目前租金与空置率数据' },
        why: { en: 'Investor verbal interest at ~$625K is waiting on the strata report', zh: '投资客 ~$625K 口头意向正等物业报告再定' },
      },
      {
        to: { en: 'Admin', zh: '行政' }, level: 'normal',
        text: { en: 'Prep the school-catchment letter and body-corp fee sheet for OFI families', zh: '为 OFI 家庭备好学区证明与物业费清单' },
        why: { en: 'inspections show 2 groups #school-zone-question #body-corp-fee', zh: 'inspections 有 2 组 #学区疑虑 #物业费' },
      },
    ],
  },
  {
    id: 'cbd-studio',
    chip: { en: 'CBD Studio', zh: 'CBD 单间公寓' },
    status: { en: 'For sale', zh: '在售' },
    brief: {
      positioning: { en: 'High-floor Melbourne CBD studio · 42㎡ · price guide $380K–$410K', zh: '墨尔本 CBD 高层单间 · 套内 42㎡ · 指导价 $380K–$410K' },
      buyer: { en: 'Yield-focused investors + first-time city buyers', zh: '看重现金流的投资客 + 首次进城置业者' },
      sell: [
        { en: 'High-floor city skyline views', zh: '高楼层城市天际线景观' },
        { en: 'Steps from trams & universities', zh: '紧邻电车与大学' },
        { en: 'Fully furnished, consistently tenanted', zh: '全套家具，长期满租' },
      ],
      tone: { en: 'Yield-led for investors; RED post = free city-life vibe', zh: '投资看现金流；小红书走城市自由生活感' },
    },
    records: {
      inspections: [
        { text: { en: '06-15 investor (overseas) inspected by video, asked for the current lease & yield', zh: '06-15 投资客（海外）视频看房，要现有租约与回报率' }, tags: ['投资客', '回报率'] },
        { text: { en: '06-12 young buyer liked the skyline view, asked about owner-occupier loan options', zh: '06-12 年轻买家喜欢天际线景观，问自住贷款方案' }, tags: ['自住客', '贷款疑问'] },
      ],
      enquiries: [
        { text: { en: 'WeChat enquiry Mr. Guo (investor), wants net yield after fees, hot', zh: '微信询盘 郭先生（投资客），要扣费后净回报，热度高' }, tags: ['热门买家', '待回访'] },
        { text: { en: 'Web form Ms. Sun (first city home), asks about furniture inclusion & strata', zh: '网站表单 孙小姐（首次进城），问家具是否含、物业费多少' }, tags: ['待回访'] },
      ],
      vendor: [
        { text: { en: 'Vendor Mr. Zhao wants $410K, will take $390K; overseas, wants a quick clean sale', zh: '业主赵先生期望 $410K，可接受 $390K；人在海外，想快速干净成交' }, tags: ['急售', '可议价'] },
      ],
      offers: [
        { text: { en: '06-15 investor verbal offer $385K subject to seeing the lease; below the $390K floor by $5K', zh: '06-15 投资客口头出价 $385K，需看租约后确认；离 $390K 底线差 $5K' }, tags: ['待回访', '临门一脚'] },
      ],
    },
    generated: {
      listing: {
        en: 'A high-floor CBD studio with city skyline views, steps from trams, universities and Melbourne Central. Fully furnished and consistently tenanted — a turnkey investment with strong yield in Melbourne’s core rental market. Price guide $380K–$410K; quick, clean sale, inspect by appointment.',
        zh: '位于高楼层、坐拥城市天际线景观的 CBD 单间公寓，紧邻电车、大学与 Melbourne Central。全套家具、长期满租——是墨尔本核心租赁市场中收益稳健的「即买即收」投资标的。指导价 $380K–$410K，快速干净成交，预约看房。',
      },
      xhs: {
        en: '📍Melbourne CBD high-floor studio｜city-view home\n\nTram downstairs, walk to uni & malls, fully furnished & long-term tenanted. A cash-flow pick for investors, hands-off rent👌\n\n#MelbourneInvestment #CBD #ApartmentInvesting #YieldProperty',
        zh: '📍墨尔本 CBD 高层单间｜城景房\n\n楼下电车，走路到大学和商场，全套家具长期满租。投资党的现金流好房，省心收租型👌\n\n#墨尔本投资房 #CBD #公寓投资 #收益房',
      },
      wechat: {
        en: 'CBD high-floor studio, city views, tram downstairs, walk to uni & malls, fully furnished & long-term tenanted. Steady cash flow, guide from $380K, DM for investment.',
        zh: 'CBD 高层单间，城景房，楼下电车、走路到大学商场，全套家具长期满租。现金流稳，指导价 $380K 起，投资私信我。',
      },
      brochure: {
        en: '1. Cover — CBD Studio · city skyline · Melbourne CBD; guide $380K–$410K\n2. Layout — 1 bed / 1 bath; 42㎡ internal; high-floor city view\n3. Selling points — skyline views｜steps from trams & uni｜furnished & tenanted\n4. Surroundings — trams, universities, Melbourne Central on foot\n5. Price & contact — guide range · agent · quick settlement · current lease available',
        zh: '1. 封面 — CBD 单间 · 城市天际线 · 墨尔本 CBD；指导价 $380K–$410K\n2. 户型布局 — 1 房 / 1 卫；套内 42㎡；高楼层城景\n3. 核心卖点 — 天际线景观｜紧邻电车与大学｜带家具且满租\n4. 周边配套 — 电车、大学、Melbourne Central 步行可达\n5. 价格与联系 — 指导价区间 · 中介 · 快速交割 · 现有租约可提供',
      },
    },
    followUps: [
      {
        to: { en: 'Agent', zh: '中介' }, level: 'hot',
        text: { en: 'Send the current lease to the $385K offerer and push to $390K (vendor floor)', zh: '把现有租约发给 $385K 出价方，争取加到 $390K（业主底线）' },
        why: { en: 'Verbal offer only $5K below the floor, subject to lease; vendor wants a quick sale', zh: '口头出价离底线仅差 $5K，看完租约即可定；业主想快速成交' },
      },
      {
        to: { en: 'Agent', zh: '中介' }, level: 'normal',
        text: { en: 'Send Mr. Guo the net-yield breakdown after strata & fees', zh: '给郭先生发扣除物业费后的净回报测算' },
        why: { en: 'Hot investor enquiry asked specifically for net yield', zh: '热门投资询盘明确要扣费后净回报' },
      },
      {
        to: { en: 'Admin', zh: '行政' }, level: 'normal',
        text: { en: 'Prep the furniture-inclusion list & strata sheet for Ms. Sun', zh: '为孙小姐备好家具清单与物业费说明' },
        why: { en: 'enquiries: first city buyer asked about furniture & strata', zh: 'enquiries：首次进城买家问家具与物业费' },
      },
    ],
  },
];

// Tag labels are authored in Chinese in the data above; map to EN for the English locale.
const TAG_EN: Record<string, string> = {
  热门买家: 'Hot buyer',
  学区疑虑: 'School-zone question',
  二次看房: 'Second viewing',
  价格异议: 'Price objection',
  待回访: 'To follow up',
  急售: 'Urgent sale',
  价格底线: 'Price floor',
  临门一脚: 'Close to closing',
  物业费: 'Strata fees',
  投资客: 'Investor',
  租金回报: 'Rental yield',
  可议价: 'Negotiable',
  交割灵活: 'Flexible settlement',
  观望: 'Watching',
  回报率: 'Yield',
  自住客: 'Owner-occupier',
  贷款疑问: 'Loan question',
};
const localizeTags = (tags: string[]) => (locale === 'zh' ? tags : tags.map((t) => TAG_EN[t] ?? t));

// ---- localize to plain strings for the inline script ----
const projectsLocalized = projects.map((p) => ({
  id: p.id,
  chip: p.chip[locale],
  status: p.status[locale],
  brief: {
    positioning: p.brief.positioning[locale],
    buyer: p.brief.buyer[locale],
    sell: p.brief.sell.map((s) => s[locale]),
    tone: p.brief.tone[locale],
  },
  records: {
    inspections: p.records.inspections.map((r) => ({ text: r.text[locale], tags: localizeTags(r.tags) })),
    enquiries: p.records.enquiries.map((r) => ({ text: r.text[locale], tags: localizeTags(r.tags) })),
    vendor: p.records.vendor.map((r) => ({ text: r.text[locale], tags: localizeTags(r.tags) })),
    offers: p.records.offers.map((r) => ({ text: r.text[locale], tags: localizeTags(r.tags) })),
  },
  generated: {
    listing: p.generated.listing[locale],
    xhs: p.generated.xhs[locale],
    wechat: p.generated.wechat[locale],
    brochure: p.generated.brochure[locale],
  },
  followUps: p.followUps.map((f) => ({ to: f.to[locale], level: f.level, text: f.text[locale], why: f.why[locale] })),
}));

const recordGroupsLocalized = recordGroups.map((g) => ({ id: g.id, icon: g.icon, label: g.label[locale] }));
const channelMetaLocalized = channelMeta.map((c) => ({ id: c.id, icon: c.icon, label: c.label[locale] }));

const projectsJson = JSON.stringify(projectsLocalized);
const recordGroupsJson = JSON.stringify(recordGroupsLocalized);
const channelMetaJson = JSON.stringify(channelMetaLocalized);

const first = projectsLocalized[0];
const contactHref = localizedHref('/contact/', locale);
const hubHref = localizedHref('/demo/', locale);

const description = zh
  ? '中介省心营销大脑：把一套房的卖点和客户动态填一次，AI 几秒帮你写好挂牌、小红书、朋友圈、楼书，还提醒你该先跟进谁。省下文案美工费。模拟演示。'
  : 'The agency’s marketing brain: fill a listing’s selling points and client activity once, and AI writes the listing, RED, WeChat and brochure in seconds — and reminds you who to chase. Saves the copywriter & designer cost. Simulated demo.';
---

<BaseLayout title={zh ? 'Demo · 中介营销大脑' : 'Demo · Agency Marketing Brain'} description={description} locale={locale}>
  <PageHero sectionLabel={copy.sectionLabel} title={copy.title} subtitle={copy.subtitle} />

  <section class="am">
    <div class="am__inner container-x">
      <a href={hubHref} class="am__back">{copy.backToHub}</a>

      <!-- Project selector -->
      <div class="am__projects" id="am-projects" role="tablist" aria-label="projects">
        {projectsLocalized.map((p, i) => (
          <button class={`am__proj${i === 0 ? ' is-on' : ''}`} type="button" data-proj={p.id} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>
            <span class="am__proj-icon">🏠</span>
            <span class="am__proj-name">{p.chip}</span>
            <span class="am__proj-status">{p.status}</span>
          </button>
        ))}
      </div>

      <!-- Pipeline motif: design.md + records → 🧠 LLM → generated -->
      <div class="am__pipe card-glass" aria-hidden="true">
        <div class="pl">
          <div class="pl__you" id="am-pin">
            <span class="pl__you-icon">📥</span>
            <span class="pl__you-label">{copy.pipeInput}</span>
          </div>
          <div class="pl__link pl__link--h" data-link="in"><i></i><i></i><i></i></div>
          <div class="pl__brain" id="am-brain">
            <span class="pl__brain-icon">🧠</span>
            <span class="pl__brain-name">{copy.pipeBrain}</span>
            <span class="pl__brain-core"><span class="pl__brain-core-spark">✦</span>{copy.pipeLlm}<span class="pl__brain-core-note">{copy.pipeLlmNote}</span></span>
            <span class="pl__brain-state" id="am-state">{copy.pipeIdle}</span>
          </div>
          <div class="pl__link pl__link--h" data-link="out"><i></i><i></i><i></i></div>
          <div class="pl__you" id="am-pout">
            <span class="pl__you-icon">📤</span>
            <span class="pl__you-label">{copy.pipeOutput}</span>
          </div>
        </div>
      </div>

      <!-- Capability strip -->
      <div class="am__caps card-glass">
        <span class="am__caps-label">{copy.capsLabel}</span>
        <div class="am__caps-row">
          {copy.caps.map((c) => (
            <div class="am__cap" data-cap={c.id}>
              <span class="am__cap-icon">{c.icon}</span>
              <span class="am__cap-name">{c.label}</span>
              <span class="am__cap-desc">{c.desc}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- 50/50 stage -->
      <div class="am__stage">
        <!-- LEFT: INPUT — file tree -->
        <aside class="am__left card-glass">
          <header class="am__panel-head">
            <span class="am__tree-root">🏠 <span id="am-tree-root">{first.chip}</span></span>
            <span class="am__panel-tag">{copy.inputTag}</span>
          </header>

          <div class="am__file">
            <div class="am__file-label">📝 {copy.designLabel}</div>
            <div class="am__brief" id="am-brief">
              <div class="am__brief-row"><span class="am__brief-k">{copy.briefPos}</span><span class="am__brief-v" data-brief="positioning">{first.brief.positioning}</span></div>
              <div class="am__brief-row"><span class="am__brief-k">{copy.briefBuyer}</span><span class="am__brief-v" data-brief="buyer">{first.brief.buyer}</span></div>
              <div class="am__brief-row"><span class="am__brief-k">{copy.briefSell}</span>
                <ol class="am__sell" data-brief="sell">
                  {first.brief.sell.map((s) => <li>{s}</li>)}
                </ol>
              </div>
              <div class="am__brief-row"><span class="am__brief-k">{copy.briefTone}</span><span class="am__brief-v" data-brief="tone">{first.brief.tone}</span></div>
            </div>
          </div>

          <div class="am__file">
            <div class="am__file-label">📇 {copy.recordsLabel}</div>
            <div class="am__records" id="am-records"></div>
          </div>
        </aside>

        <!-- RIGHT: OUTPUT — generated -->
        <div class="am__right card-glass">
          <header class="am__panel-head">
            <span class="am__tree-root">✨ {copy.outputTitle}</span>
            <span class="am__panel-tag">{copy.outputTag}</span>
            <button class="am__regen" id="am-regen" type="button">{copy.regenerate}</button>
          </header>

          <div class="am__writing" id="am-writing" hidden>
            <span class="am__writing-spark">✦</span>
            <span class="am__writing-text">{copy.regenerating}</span>
            <span class="am__dots"><i></i><i></i><i></i></span>
          </div>

          <div class="am__out" id="am-out" aria-live="polite"></div>

          <footer class="am__appfoot">
            <span class="am__disclaimer">⚠︎ {copy.disclaimer}</span>
          </footer>
        </div>
      </div>

      <!-- Clone note -->
      <p class="am__clone">📋 {copy.cloneNote}</p>

      <!-- Explainer -->
      <div class="am__explain">
        <span class="section-label">{copy.explainLabel}</span>
        <h2 class="am__explain-title">{copy.explainTitle}</h2>
        <ul class="am__points">
          {copy.explainPoints.map((p) => <li>{p}</li>)}
        </ul>
        <div class="am__try">
          <p>{copy.ctaTryYours}</p>
          <a href={contactHref} class="btn-primary">{copy.ctaBtn} →</a>
        </div>
      </div>
    </div>
  </section>

  <CtaFooter locale={locale} sectionNumber="03" />
</BaseLayout>

<script is:inline define:vars={{
  projectsJson, recordGroupsJson, channelMetaJson,
  labels: {
    assignedTo: copy.assignedTo,
    regenerate: copy.regenerate,
    regenerating: copy.regenerating,
    stateIdle: copy.pipeIdle,
    stateWorking: copy.pipeWorking,
    stateDone: copy.pipeDone,
    whySep: zh ? '：' : ': ',
  },
}}>
  function initAgencyMemory() {
    var section = document.querySelector('.am');
    if (!section || section.getAttribute('data-init') === '1') return;
    section.setAttribute('data-init', '1');

    var projChips = document.getElementById('am-projects');
    var treeRoot = document.getElementById('am-tree-root');
    var brief = document.getElementById('am-brief');
    var recordsEl = document.getElementById('am-records');
    var out = document.getElementById('am-out');
    var writing = document.getElementById('am-writing');
    var regenBtn = document.getElementById('am-regen');
    var brain = document.getElementById('am-brain');
    var stateEl = document.getElementById('am-state');
    var pipe = document.querySelector('.am__pipe');
    var capsRow = document.querySelector('.am__caps');
    if (!out || !recordsEl) return;

    var PROJECTS = JSON.parse(projectsJson);
    var GROUPS = JSON.parse(recordGroupsJson);
    var CHANNELS = JSON.parse(channelMetaJson);
    var byId = {};
    PROJECTS.forEach(function (p) { byId[p.id] = p; });

    var currentId = PROJECTS[0].id;
    var busy = false;
    var timers = [];

    function t(fn, ms) { timers.push(setTimeout(fn, ms)); }
    function clearTimers() { timers.forEach(clearTimeout); timers.length = 0; }

    function setBrief(p) {
      function set(name, val) {
        var el = brief ? brief.querySelector('[data-brief="' + name + '"]') : null;
        if (el) el.textContent = val;
      }
      set('positioning', p.brief.positioning);
      set('buyer', p.brief.buyer);
      set('tone', p.brief.tone);
      var sell = brief ? brief.querySelector('[data-brief="sell"]') : null;
      if (sell) {
        sell.innerHTML = '';
        p.brief.sell.forEach(function (s) {
          var li = document.createElement('li');
          li.textContent = s;
          sell.appendChild(li);
        });
      }
    }

    function renderRecords(p) {
      recordsEl.innerHTML = '';
      GROUPS.forEach(function (g) {
        var rows = p.records[g.id] || [];
        var group = document.createElement('div');
        group.className = 'am__rgroup';
        group.setAttribute('data-group', g.id);

        var head = document.createElement('div');
        head.className = 'am__rgroup-head';
        head.textContent = g.icon + ' ' + g.label;
        group.appendChild(head);

        rows.forEach(function (r) {
          var row = document.createElement('div');
          row.className = 'am__rrow';
          var txt = document.createElement('span');
          txt.className = 'am__rrow-text';
          txt.textContent = r.text;
          row.appendChild(txt);
          if (r.tags && r.tags.length) {
            var tags = document.createElement('span');
            tags.className = 'am__rtags';
            r.tags.forEach(function (tg) {
              var chip = document.createElement('span');
              chip.className = 'am__rtag';
              chip.textContent = '#' + tg;
              tags.appendChild(chip);
            });
            row.appendChild(tags);
          }
          group.appendChild(row);
        });
        recordsEl.appendChild(group);
      });
    }

    function lightRecords(on) {
      var groups = recordsEl.querySelectorAll('.am__rgroup');
      groups.forEach(function (g) { g.classList.toggle('is-active', on); });
    }

    function buildChannelCard(meta, text) {
      var card = document.createElement('div');
      card.className = 'am__card';
      card.setAttribute('data-channel', meta.id);

      var head = document.createElement('div');
      head.className = 'am__card-head';
      var label = document.createElement('span');
      label.className = 'am__card-label';
      label.textContent = meta.icon + ' ' + meta.label;
      head.appendChild(label);
      card.appendChild(head);

      var body = document.createElement('div');
      body.className = 'am__card-body am__card-text';
      body.textContent = text;
      card.appendChild(body);
      return card;
    }

    function buildFollowUpsCard(p) {
      var card = document.createElement('div');
      card.className = 'am__card am__card--follow';
      card.setAttribute('data-channel', 'follow-ups');

      var head = document.createElement('div');
      head.className = 'am__card-head';
      var label = document.createElement('span');
      label.className = 'am__card-label';
      label.textContent = '📌 follow-ups.md · ' + (labels.assignedTo === 'To' ? 'AI follow-ups' : 'AI 派跟进');
      head.appendChild(label);
      card.appendChild(head);

      var body = document.createElement('div');
      body.className = 'am__card-body';
      p.followUps.forEach(function (f) {
        var task = document.createElement('div');
        task.className = 'am__task' + (f.level === 'hot' ? ' is-hot' : '');
        var th = document.createElement('div');
        th.className = 'am__task-head';
        var to = document.createElement('span');
        to.className = 'am__task-to';
        to.textContent = '🧠 ' + labels.assignedTo + ' ' + f.to;
        th.appendChild(to);
        if (f.level === 'hot') {
          var hot = document.createElement('span');
          hot.className = 'am__task-flag';
          hot.textContent = '🔴';
          th.appendChild(hot);
        }
        task.appendChild(th);
        var tt = document.createElement('div');
        tt.className = 'am__task-text';
        tt.textContent = f.text;
        task.appendChild(tt);
        var tw = document.createElement('div');
        tw.className = 'am__task-why';
        tw.textContent = f.why;
        task.appendChild(tw);
        body.appendChild(task);
      });
      card.appendChild(body);
      return card;
    }

    function buildAllCards(p) {
      var cards = [];
      CHANNELS.forEach(function (meta) {
        cards.push(buildChannelCard(meta, p.generated[meta.id]));
      });
      cards.push(buildFollowUpsCard(p));
      return cards;
    }

    function activateCap(id) {
      if (!capsRow) return;
      var cap = capsRow.querySelector('.am__cap[data-cap="' + id + '"]');
      if (cap) cap.classList.add('is-active');
    }
    function clearCaps() {
      if (!capsRow) return;
      capsRow.querySelectorAll('.am__cap.is-active').forEach(function (c) { c.classList.remove('is-active'); });
    }

    function flow(dir, on) {
      if (!pipe) return;
      var l = pipe.querySelector('.pl__link[data-link="' + dir + '"]');
      if (l) l.classList.toggle('is-flowing', on);
    }

    // Show the finished generated/ output immediately — visitors land on a result.
    function renderInstant() {
      clearTimers();
      busy = false;
      if (writing) writing.hidden = true;
      out.innerHTML = '';
      var p = byId[currentId];
      if (!p) return;
      buildAllCards(p).forEach(function (card) {
        card.classList.add('is-in');
        out.appendChild(card);
      });
      activateCap('classify'); activateCap('generate'); activateCap('assign');
      if (stateEl) stateEl.textContent = labels.stateDone;
    }

    function applyProject(id) {
      currentId = id;
      var p = byId[id];
      if (!p) return;
      if (treeRoot) treeRoot.textContent = p.chip;
      setBrief(p);
      renderRecords(p);
      renderInstant();
    }

    // Replay the generation animation: records light → brain works → cards reveal in sequence.
    function regenerate() {
      if (busy) return;
      busy = true;
      clearTimers();
      var p = byId[currentId];
      if (!p) { busy = false; return; }

      out.innerHTML = '';
      clearCaps();
      if (writing) writing.hidden = false;
      if (regenBtn) regenBtn.disabled = true;
      if (brain) brain.classList.add('is-working');
      if (stateEl) stateEl.textContent = labels.stateWorking;
      flow('in', true);
      lightRecords(true);
      activateCap('classify');

      t(function () {
        flow('in', false);
        flow('out', true);
        activateCap('generate');
        if (writing) writing.hidden = true;
        var cards = buildAllCards(p);
        var i = 0;
        function next() {
          if (i >= cards.length) {
            lightRecords(false);
            flow('out', false);
            if (brain) brain.classList.remove('is-working');
            if (stateEl) stateEl.textContent = labels.stateDone;
            activateCap('assign');
            if (regenBtn) regenBtn.disabled = false;
            busy = false;
            return;
          }
          var card = cards[i];
          out.appendChild(card);
          t(function () { card.classList.add('is-in'); }, 20);
          out.scrollTop = out.scrollHeight;
          i += 1;
          t(next, 520);
        }
        next();
      }, 900);
    }

    if (projChips) {
      projChips.addEventListener('click', function (e) {
        var btn = e.target.closest('.am__proj');
        if (!btn || busy) return;
        var id = btn.getAttribute('data-proj');
        if (id === currentId) return;
        projChips.querySelectorAll('.am__proj').forEach(function (c) {
          c.classList.remove('is-on'); c.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('is-on'); btn.setAttribute('aria-selected', 'true');
        applyProject(id);
      });
    }

    if (regenBtn) regenBtn.addEventListener('click', regenerate);

    // Land on the designed example, fully rendered.
    renderRecords(byId[currentId]);
    renderInstant();
  }

  initAgencyMemory();
  document.addEventListener('astro:after-swap', initAgencyMemory);
</script>

