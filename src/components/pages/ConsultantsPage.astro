<script>
  // Capability chip popover — explains each tech/cert chip on hover, focus, or tap.
  function initCapabilityPopover() {
    const popover = document.getElementById('capability-popover');
    if (!popover) return;

    const chips = document.querySelectorAll<HTMLButtonElement>('.capability-chip');
    let activeChip: HTMLButtonElement | null = null;

    function show(chip: HTMLButtonElement) {
      if (!popover) return;
      const text = chip.dataset.explain ?? '';
      if (!text) return;

      popover.textContent = text;
      popover.classList.add('is-visible');
      popover.setAttribute('aria-hidden', 'false');
      activeChip = chip;

      // Position centered below the chip, flipped above if it would overflow.
      const chipRect = chip.getBoundingClientRect();
      const popRect = popover.getBoundingClientRect();
      const margin = 12;

      let left = chipRect.left + chipRect.width / 2 - popRect.width / 2;
      left = Math.max(margin, Math.min(left, window.innerWidth - popRect.width - margin));

      let top = chipRect.bottom + 8;
      if (top + popRect.height > window.innerHeight - margin) {
        top = chipRect.top - popRect.height - 8;
      }

      popover.style.left = `${left}px`;
      popover.style.top = `${top}px`;
    }

    function hide() {
      if (!popover) return;
      popover.classList.remove('is-visible');
      popover.setAttribute('aria-hidden', 'true');
      activeChip = null;
    }

    // Only attach hover handlers on devices that can actually hover (desktop
    // with a mouse). Touch devices simulate mouseenter/mouseleave in ways
    // that would cause the popover to flicker right after a tap.
    const canHover = window.matchMedia('(hover: hover)').matches;

    chips.forEach((chip) => {
      if (canHover) {
        chip.addEventListener('mouseenter', () => show(chip));
        chip.addEventListener('mouseleave', (e) => {
          const related = e.relatedTarget as Node | null;
          if (related && popover.contains(related)) return;
          hide();
        });
      }

      chip.addEventListener('focus', () => show(chip));
      chip.addEventListener('blur', (e) => {
        // If focus moves to another chip, let its focus handler take over —
        // avoids a hide/show flicker between sibling chips.
        const related = e.relatedTarget as Element | null;
        if (related && related.classList.contains('capability-chip')) return;
        hide();
      });

      chip.addEventListener('click', (e) => {
        // Click always shows. Dismissal happens via outside-click, Escape,
        // blur, scroll, or tapping another chip (which replaces content).
        // Previously this was a toggle, but focus fires before click on
        // touch + keyboard, making the popover hide immediately after
        // the focus handler showed it.
        e.preventDefault();
        show(chip);
      });
    });

    // Dismiss on outside click or Escape
    document.addEventListener('click', (e) => {
      const target = e.target as Element | null;
      if (!target) return;
      if (target.closest('.capability-chip') || target.closest('.capability-popover')) return;
      hide();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') hide();
    });
    window.addEventListener('scroll', hide, { passive: true });
    window.addEventListener('resize', hide, { passive: true });
  }

  initCapabilityPopover();
  document.addEventListener('astro:after-swap', initCapabilityPopover);
</script>

